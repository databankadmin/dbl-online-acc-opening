    <h4 class="myHeader">Declaration by Applicant(s)</h4>
    <div class="form-row">
        <div class="form-flex">

            <div class="form-group" style="width:95%;">
                <label for="declarationHasBeenConvicted" class="form-label">
                    Have you been convicted in any Court of Law for a criminal offence or are there any proceedings
                    now pending against you which may lead to such a conviction?
                </label>
                <select name="declarationHasBeenConvicted" id="declarationHasBeenConvicted" style="width:300px;">
                    <option value="">-select-</option>
                    <option value="YES">YES</option>
                    <option value="NO">NO</option>
                </select>
            </div>

            <div class="form-group" style="float:right;">
                <label for="convictionDetails" class="form-label">Provide Details</label>
                <input type="text" name="convictionDetails" id="convictionDetails" style="height:100px;" />
            </div>

        </div>
    </div>




    <div class="form-row">
        <div class="form-flex">
            <div class="form-group" style="width:95%;">
                <label for="actingAsNominee" class="form-label">
                    Are you acting as a nominee in trust for others?
                </label>
                <select name="actingAsNominee" id="actingAsNominee" style="width:300px;">
                    <option value="">-select-</option>
                    <option value="YES">YES</option>
                    <option value="NO">NO</option>
                </select>
            </div>

            <div class="form-group" style="float:right;">
                <label for="actingAsNomineeName" class="form-label">Name</label>
                <input type="text" name="actingAsNomineeName" id="actingAsNomineeName" />
            </div>

        </div>
    </div>




    <div class="form-row">
        <div class="form-flex">
            I/We <input type="text" name="singleAccDeclarationFullName" id="singleAccDeclarationFullName" />

        </div>
    </div>
    <div class="form-row">
        <div class="form-flex">
            , hereby declare that I/we am/are not involved in or related to any act of or dealing with the tracking of narcotics and dangerous drugs and proceeds of such tracking. I declare that the information provided in this form is true and complete. I undertake to notify Databank Brokerage Limited immediately in writing of any change in particulars or information provided above.

        </div>
    </div>


    <br/>
    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="numberOfSignatories" class="form-label">Indicate the Number of Signatories</label>
                <select name="numberOfSignatories" id="numberOfSignatories" style="width:300px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.SignatureTypes.OrderBy(x => x.Id))
                        {
                          
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>

            </div>
        </div>
    </div>



</fieldset>
