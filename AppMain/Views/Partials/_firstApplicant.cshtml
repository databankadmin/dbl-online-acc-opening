@using DBHelper.Schema
@{
    var context = new DBLAccountOpeningContext();
    var accountType = context.AccountTypes.Find(MvcApplication.AccountType);
}

<fieldset>
    <h2>Databank Brokerage Form | @accountType.Name</h2>


    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="investmentType" class="form-label">Investment Type</label>
                <select name="csdResidentialStatus" id="investmentType" style="width:300px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.InvestmentTypes.Where(x => x.IsActive))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>

            </div>
            <div class="form-group">
                <label for="dblAccNumber" class="form-label">Account Number.</label>
                <input type="text" name="dblAccNumber" id="dblAccNumber" />
            </div>

            <div class="form-group">
                <label for="dblCsdNumber" class="form-label">CSD Number</label>
                <input type="text" name="dblCsdNumber" id="dblCsdNumber" />
            </div>
        </div>
    </div>


    <h4 class="myHeader">FIRST APPLICANT</h4>

    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="firstApplicantTitle" class="form-label">Title</label>
                <select name="firstApplicantTitle" id="firstApplicantTitle" style="width:300px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Titles)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>


            <div class="form-group">
                <label for="firstApplicantSurname" class="form-label">Surname</label>
                <input type="text" name="firstApplicantSurname" id="firstApplicantSurname" />
            </div>

            <div class="form-group">
                <label for="firstApplicantFname" class="form-label">First Name</label>
                <input type="text" name="firstApplicantFname" id="firstApplicantFname" />
            </div>
            <div class="form-group">
                <label for="firstApplicantOname" class="form-label">Other Name</label>
                <input type="text" name="firstApplicantOname" id="firstApplicantOname" />
            </div>
        </div>
    </div>


    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="firstApplicantNationality" class="form-label">Nationality</label>
                <select name="firstApplicantNationality" id="firstApplicantNationality" style="width:300px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                        {
                            if (item.ID == 81)
                            {
                                <option value="@item.ID" selected>@item.CountryName</option>
                                continue;

                            }
                            <option value="@item.ID">@item.CountryName</option>
                        }
                    }
                </select>

            </div>

            <div class="form-group">
                <label for="firstApplicantDOB" class="form-label" style="font-size:14px;">Date of Birth</label>
                <input type="date" name="firstApplicantDOB" id="firstApplicantDOB" />
            </div>

            <div class="form-group">
                <label for="firstApplicantPlaceOfBirth" class="form-label">Place of Birth</label>
                <input type="text" name="firstApplicantPlaceOfBirth" id="firstApplicantPlaceOfBirth" />
            </div>




        </div>
    </div>


    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="firstApplicantMaritalStatus" class="form-label">Marital Status</label>
                <select name="firstApplicantMaritalStatus" id="firstApplicantMaritalStatus" style="width:300px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.MaritalStatus.Where(x => x.IsActive))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label for="firstApplicantMotherMaidenName" class="form-label">Mother’s Maiden Name</label>
                <input type="text" name="firstApplicantMotherMaidenName" id="firstApplicantMotherMaidenName" />
            </div>

        </div>
    </div>









    <h4>Residential Address</h4>

    <div class="form-row">
        <div class="form-flex">

            <div class="form-group">
                <label for="firstApplicantResidentialCity" class="form-label">City</label>
                <input type="text" name="firstApplicantResidentialCity" id="firstApplicantResidentialCity" />
            </div>

            <div class="form-group">
                <label for="firstApplicantResidentialZipCode" class="form-label">Zip Code</label>
                <input type="text" name="firstApplicantResidentialZipCode" id="firstApplicantResidentialZipCode" />
            </div>

            <div class="form-group">
                <label for="firstApplicantResidentialCountry" class="form-label">Country</label>
                <select name="firstApplicantResidentialCountry" id="firstApplicantResidentialCountry" style="width:300px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                        {
                            if (item.ID == 81)
                            {
                                <option value="@item.ID" selected>@item.CountryName</option>
                                continue;

                            }
                            <option value="@item.ID">@item.CountryName</option>
                        }
                    }
                </select>
            </div>

        </div>
    </div>






    <h4>Mailing Address</h4>

    <div class="form-row">
        <div class="form-flex">

            <div class="form-group">
                <label for="firstApplicantMailingCity" class="form-label">City</label>
                <input type="text" name="firstApplicantMailingCity" id="firstApplicantMailingCity" />
            </div>

            <div class="form-group">
                <label for="firstApplicantMailingZipCode" class="form-label">Zip Code</label>
                <input type="text" name="firstApplicantMailingZipCode" id="firstApplicantMailingZipCode" />
            </div>

            <div class="form-group">
                <label for="firstApplicantMailingCountry" class="form-label">Country</label>
                <select name="firstApplicantMailingCountry" id="firstApplicantMailingCountry" style="width:300px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                        {
                            if (item.ID == 81)
                            {
                                <option value="@item.ID" selected>@item.CountryName</option>
                                continue;

                            }
                            <option value="@item.ID">@item.CountryName</option>
                        }
                    }
                </select>
            </div>

        </div>
    </div>



    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="firstApplicantTickApplicable" class="form-label">Select where applicable</label>
                <select name="firstApplicantTickApplicable" id="firstApplicantTickApplicable" style="width:300px;">
                    <option value="0">-select-</option>
                    @{
                        foreach (var item in context.CSDDepositoryParticipantOptions.Where(x => x.IsActive).OrderBy(x => x.Id))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label for="firstApplicantTel" class="form-label">Telephone</label>
                <input type="text" name="firstApplicantTel" id="firstApplicantTel" />
            </div>
            <div class="form-group">
                <label for="firstApplicantMobile" class="form-label">Mobile</label>
                <input type="text" name="firstApplicantMobile" id="firstApplicantMobile" />
            </div>
            <div class="form-group">
                <label for="firstApplicantFax" class="form-label">Fax</label>
                <input type="text" name="firstApplicantFax" id="firstApplicantFax" />
            </div>


        </div>
    </div>




    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="firstApplicantOccupation" class="form-label">Occupation</label>
                <input type="text" name="firstApplicantOccupation" id="firstApplicantOccupation" />
            </div>
            <div class="form-group">
                <label for="firstApplicantEmail" class="form-label">Email</label>
                <input type="email" name="firstApplicantEmail" id="firstApplicantEmail" />
            </div>
        </div>
    </div>



    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="firstApplicantIdType" class="form-label">ID Type</label>
                <select name="firstApplicantIdType" id="firstApplicantIdType" style="width:250px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.IDCardTypes.Where(x => x.IsActive).Take(4))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>

            </div>

            <div class="form-group">
                <label for="firstApplicantIdNumber" class="form-label">ID Number</label>
                <input type="email" name="firstApplicantIdNumber" id="firstApplicantIdNumber" />
            </div>

            <div class="form-group">
                <label for="firstApplicantIdIssuingAuthority" class="form-label">Issuing Authority</label>
                <input type="email" name="firstApplicantIdIssuingAuthority" id="firstApplicantIdIssuingAuthority" />
            </div>



        </div>
    </div>


    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="firstApplicantIdCardIssueDate" class="form-label">Issue Date</label>
                <input type="date" name="firstApplicantIdCardIssueDate" id="firstApplicantIdCardIssueDate" />
            </div>

            <div class="form-group">
                <label for="firstApplicantIdCardExpDate" class="form-label">Expiry Date</label>
                <input type="date" name="firstApplicantIdCardExpDate" id="firstApplicantIdCardExpDate" />
            </div>
        </div>
    </div>



    @{
        if (MvcApplication.AccountType == 2)
        {
            //joint
            @Html.Partial("~/Views/Partials/_jointApplicant.cshtml")

        }
        else if (MvcApplication.AccountType == 3)
        {
            //itf
            @Html.Partial("~/Views/Partials/_itfApplicant.cshtml")

        }
        @Html.Partial("~/Views/Partials/_nextOfKin.cshtml")
    }

    <h4 class="myHeader">Authorised Person other than Account Holder(s) to Deal on the Account</h4>

