        </div>
    </div>



    <h4 class="myHeader">Settlement Details</h4>

    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="settlementDetailsAccountName" class="form-label">Account Name</label>
                <input type="text" name="settlementDetailsAccountName" id="settlementDetailsAccountName" />
            </div>
            <div class="form-group">
                <label for="settlementDetailsAccountNumber" class="form-label">Account Number</label>
                <input type="text" name="settlementDetailsAccountNumber" id="settlementDetailsAccountNumber" />
            </div>
            <div class="form-group">
