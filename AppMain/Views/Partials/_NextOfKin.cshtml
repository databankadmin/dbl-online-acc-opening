@using DBHelper.Schema
@{
    var context = new DBLAccountOpeningContext();
    var idCards = context.IDCardTypes.Where(x => x.Id == 4 || x.Id == 5 || x.Id == 9);
}

<h4 class="myHeader">Next of Kin's Details</h4>

<h4 style="font-weight:bold">Next of Kin 1</h4>
<div class="form-row">
    <div class="form-flex">
        <div class="form-group">
            <label for="nextOfKin1Name" class="form-label">Name</label>
            <input type="text" name="nextOfKin1Name" id="nextOfKin1Name"  required/>
        </div>
        <div class="form-group">
            <label for="nextOfKin1Phone" class="form-label">Telephone</label>
            <input type="text" name="nextOfKin1Phone" id="nextOfKin1Phone" />
        </div>

        <div class="form-group">
            <label for="nextOfKin1Mobile" class="form-label">Mobile</label>
            <input type="text" name="nextOfKin1Mobile" id="nextOfKin1Mobile" required />
        </div>
        <div class="form-group">
            <label for="nextOfKin1Fax" class="form-label">Fax</label>
            <input type="text" name="nextOfKin1Fax" id="nextOfKin1Fax" />
        </div>


    </div>
</div>

<div class="form-row">
    <div class="form-flex">
        <div class="form-group">
            <label for="nextOfKin1Relation" class="form-label">Relation to the Account Holder</label>
            <input type="text" name="nextOfKin1Relation" id="nextOfKin1Relation" required/>
        </div>
        <div class="form-group">
            <label for="nextOfKin1Email" class="form-label">E-mail address</label>
            <input type="email" name="nextOfKin1Email" id="nextOfKin1Email"  />
        </div>

        <div class="form-group">
            <label for="nextOfKin1MailAddress" class="form-label">Mailing Address</label>
            <input type="text" name="nextOfKin1MailAddress" id="nextOfKin1MailAddress" />
        </div>
    </div>
</div>





