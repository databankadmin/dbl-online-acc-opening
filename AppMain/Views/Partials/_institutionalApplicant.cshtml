                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="intSettlementDetailsIntermediaryBankSwiftNo" class="form-label">Swift / Sort code</label>
                <input type="text" name="intSettlementDetailsIntermediaryBankSwiftNo" id="intSettlementDetailsIntermediaryBankSwiftNo" />
            </div>

        </div>
    </div>





    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="intSettlementDetailsNameOfBeneficiary" class="form-label">Name of Beneficiary *</label>
                <input type="text" name="intSettlementDetailsNameOfBeneficiary" id="intSettlementDetailsNameOfBeneficiary" required />
            </div>
            <div class="form-group">
                <label for="intSettlementDetailsBIC" class="form-label">BIC</label>
                <input type="text" name="intSettlementDetailsBIC" id="intSettlementDetailsBIC" />
            </div>
            <div class="form-group">
                <label for="intSettlementDetailsAccountNumber" class="form-label">Account Number *</label>
                <input type="text" name="intSettlementDetailsAccountNumber" id="intSettlementDetailsAccountNumber" required />
            </div>

        </div>
    </div>



    <div class="form-row">
        <div class="form-flex">

            <div class="form-group">
                <label for="instMarginTrationOption" class="form-label">Margin Trading Option *</label>
                <select name="instMarginTrationOption" id="instMarginTrationOption" style="width:350px;" required>
                    <option value="">-select-</option>
                    <option value="YES">YES</option>
                    <option value="NO">NO</option>
                </select>
            </div>

            <div class="form-group">
                <label for="instOnlineTradingOption" class="form-label">Online Trading Facility *</label>
                <select name="instOnlineTradingOption" id="instOnlineTradingOption" style="width:350px;" required>
                    <option value="">-select-</option>
                    <option value="YES">YES</option>
                    <option value="NO">NO</option>
                </select>
            </div>
        </div>
    </div>



    <h4 class="myHeader">INSTRUCTIONS AND FINANCIAL DETAILS</h4>

    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="intModeOfInstruction" class="form-label">Mode of Instructions *</label>
                <select name="intModeOfInstruction" id="intModeOfInstruction" style="width:250px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.ModeOfInstructions.Where(x => x.IsActive))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label for="intModeOfNotification" class="form-label">Mode of Notification *</label>
                <select name="intModeOfNotification" id="intModeOfNotification" style="width:250px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.ModeOfNotifications.Where(x => x.IsActive))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>



            <div class="form-group">
                <label for="intSourceOfIncome" class="form-label">Source(s) of Income/Funds *</label>
                <select name="intSourceOfIncome" id="intSourceOfIncome" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.SourceOfIncomes.Where(x => x.IsActive))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>


        </div>
    </div>


    <h4 class="myHeader">Account Authorised Officers</h4>

