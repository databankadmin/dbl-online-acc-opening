            <div class="form-group">
                <label for="intAuthorisedOfficer1IDNumber" class="form-label">ID Number *</label>
                <input type="text" name="intAuthorisedOfficer1IDNumber" id="intAuthorisedOfficer1IDNumber" required />
            </div>

            <div class="form-group">
                <div class="dropzone dropzone-previews" id="instAuthorisedOfficer1PhotoId" style="padding-top:2px;">
                    <center style="text-align:center;">
                        UPLOAD ID *
                    </center>
                </div>

                <input type="hidden" name="instAuthorisedOfficer1PhotoIdhidden" id="instAuthorisedOfficer1PhotoIdhidden" />

