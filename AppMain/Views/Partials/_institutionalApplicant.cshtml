@using DBHelper.Schema
@{
    var context = new DBLAccountOpeningContext();
    var accountType = context.AccountTypes.Find(MvcApplication.AccountType);
}

<fieldset>
    <h2>Databank Brokerage Form | Institutional</h2>
    <h4 style="color:red">Required fields are marked with asterisk (*)</h4>


    <div class="form-row">
        <div class="form-flex">

            <div class="form-group">
                <label for="instInvestmentType" class="form-label">Investment Type *</label>
                <select name="instInvestmentType" id="instInvestmentType" style="width:300px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.InvestmentTypes.Where(x => x.IsActive))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>

            </div>
            <div class="form-group">
                <label for="expectedAccountActivityId" class="form-label">Expected Account Activity *</label>
                <select name="expectedAccountActivityId" id="expectedAccountActivityId" style="width:300px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.ExpectedAccountActivities.OrderBy(x => x.Id))
                        {

                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label for="instNameOfClient" class="form-label">Name of Client *</label>
                <input type="text" name="instNameOfClient" id="instNameOfClient" required />
            </div>
            
        </div>
    </div>




    <div class="form-row">
        <div class="form-flex">

            <div class="form-group">
                <label for="instNatureOfBusiness" class="form-label">Nature of Business *</label>
                <input type="text" name="instNatureOfBusiness" id="instNatureOfBusiness" required />
            </div>
            <div class="form-group">
                <label for="instPricipalBroker" class="form-label">Name of Principal Broker *</label>
                <input type="text" name="instPricipalBroker" id="instPricipalBroker" required />
            </div>
            <div class="form-group">
                <label for="instCountryOfResidence" class="form-label">Country of Incorporation *</label>
                <select name="instCountryOfResidence" id="instCountryOfResidence" style="width:300px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                        {
                            if (item.ID == 81)
                            {
                                <option value="@item.ID" selected>@item.CountryName</option>
                                continue;

                            }
                            <option value="@item.ID">@item.CountryName</option>
                        }
                    }
                </select>

            </div>


        </div>
    </div>

    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="instRegistrationNumber" class="form-label">Registration Number *</label>
                <input type="text" name="instRegistrationNumber" id="instRegistrationNumber" required />
            </div>

            <div class="form-group">
                <label for="tin" class="form-label">TIN Number</label>
                <input type="text" name="tin" id="tin" />
            </div>

        </div>
    </div>


    <p>
        Mailing Address

        <input type="text" style="width:89%;" name="instFullMailingAddress" id="instFullMailingAddress" />

    </p>
    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="instMailingAddressCity" class="form-label">City</label>
                <input type="text" name="instMailingAddressCity" id="instMailingAddressCity" />
            </div>
            <div class="form-group">
                <label for="instMailAddressCountryOfResidence" class="form-label">Country *</label>
                <select name="instMailAddressCountryOfResidence" id="instMailAddressCountryOfResidence" style="width:300px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                        {
                            if (item.ID == 81)
                            {
                                <option value="@item.ID" selected>@item.CountryName</option>
                                continue;

                            }
                            <option value="@item.ID">@item.CountryName</option>
                        }
                    }
                </select>
            </div>

        </div>
    </div>




    <p>
        Street Address
        <input type="text" style="width:89%;" name="instFullStreetAddress" id="instFullStreetAddress" />

    </p>
    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="instSteetAddressCity" class="form-label">City</label>
                <input type="text" name="instSteetAddressCity" id="instSteetAddressCity" />
            </div>

            <div class="form-group">
                <label for="instSteetAddressZipCode" class="form-label">Zip Code/GhanaPost Code</label>
                <input type="text" name="instSteetAddressZipCode" id="instSteetAddressZipCode" />
            </div>

            <div class="form-group">
                <label for="instSteetAddressCountry" class="form-label">Country *</label>
                <select name="instSteetAddressCountry" id="instSteetAddressCountry" style="width:300px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                        {
                            if (item.ID == 81)
                            {
                                <option value="@item.ID" selected>@item.CountryName</option>
                                continue;

                            }
                            <option value="@item.ID">@item.CountryName</option>
                        }
                    }
                </select>
            </div>

        </div>
    </div>



    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="instTelephone" class="form-label">Telephone *</label>
                <input type="text" name="instTelephone" id="instTelephone" required />
            </div>
            <div class="form-group">
                <label for="instFax" class="form-label">Fax</label>
                <input type="text" name="instFax" id="instFax" />
            </div>
            <div class="form-group">
                <label for="instEmail" class="form-label">Email *</label>
                <input type="email" name="instEmail" id="instEmail" required />
            </div>



        </div>
    </div>


    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="instCompanyType" class="form-label">Select applicable suffix *</label>
                <select name="instCompanyType" id="instCompanyType" style="width:200px;" required>
                    <option value="">-select-</option>
                    <option value="LC">Local Company</option>
                    <option value="FC">Foreign Company</option>
                </select>
            </div>


            <div class="form-group">
                <label for="instRegionalInvestmentId" class="form-label">Regional Investment Interest *</label>
                <select name="instRegionalInvestmentId" id="instRegionalInvestmentId" style="width:300px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.RegionalInvesmentInterests.OrderBy(x => x.Id))
                        {

                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>


            <div class="form-group">
                <label for="instStatementFreq" class="form-label">Frequency of Account Statements *</label>
                <select name="instStatementFreq" id="instStatementFreq" style="width:300px;" required>
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.StatementFrequencies.OrderBy(x => x.Id))
                        {

                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>


        </div>
    </div>


    <h4 class="myHeader">CUSTODY ACCOUNT DETAILS</h4>
    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="custodyDetailsName" class="form-label">Custodian Name *</label>
                <input type="text" name="custodyDetailsName" id="custodyDetailsName" required />
            </div>


            <div class="form-group">
                <label for="custodyDetailsPhone" class="form-label">Telephone *</label>
                <input type="text" name="custodyDetailsPhone" id="custodyDetailsPhone" required />
            </div>


            <div class="form-group">
                <label for="custodyDetailsAddress" class="form-label">Address *</label>
                <input type="text" name="custodyDetailsAddress" id="custodyDetailsAddress" required />
            </div>


        </div>
    </div>


    <div class="form-row">
        <div class="form-flex">
            <div class="form-group">
                <label for="custodyDetailsFax" class="form-label">Fax</label>
                <input type="text" name="custodyDetailsFax" id="custodyDetailsFax" />
            </div>


            <div class="form-group">
                <label for="custodyDetailsCashAccNumber" class="form-label">Cash Account Number</label>
                <input type="text" name="custodyDetailsCashAccNumber" id="custodyDetailsCashAccNumber" />
            </div>


            <div class="form-group">
                <label for="custodyDetailsSecuritiesAccNumber" class="form-label">Securities Account Number</label>
                <input type="text" name="custodyDetailsSecuritiesAccNumber" id="custodyDetailsSecuritiesAccNumber" />
            </div>

        </div>
    </div>

    <h4 class="myHeader">SETTLEMENT DETAILS</h4>
    <div class="form-row">
        <div class="form-flex">

            <div class="form-group">
                <label for="intSettlementDetailsCorrespondentBankId" class="form-label">Correspondent Bank *</label>
                <select required name="intSettlementDetailsCorrespondentBankId" id="intSettlementDetailsCorrespondentBankId" style="width:350px;">
                    <option value="">-select-</option>
                    @{
                        foreach (var item in context.Banks.Where(x => x.IsActive).OrderBy(x => x.Name))
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="intSettlementDetailsCorrespondentBankSwiftNo" class="form-label">Swift / Sort code</label>
                <input type="text" name="intSettlementDetailsCorrespondentBankSwiftNo" id="intSettlementDetailsCorrespondentBankSwiftNo" />
            </div>

        </div>
    </div>



    <div class="form-row">
        <div class="form-flex">

            <div class="form-group">
                <label for="intSettlementDetailsIntermediaryBankId" class="form-label">Intermediary Bank *</label>
