@model AppModels.AccountBasicModel
@using AppUtils
@using AppModels
@using AppMain.Providers

@{
    ViewBag.Title = "Applicant Profile | " + Model.AccountName;
    Layout = "~/Views/Shared/_pdfLayout.cshtml";
    Guid applicationId = Guid.Parse(ViewBag.applicationId.ToString());

    var accountAuthorisedPersons = Utilities.GetAccountAuthorisedPersons(applicationId);
    var accountETI = Utilities.GetAccountETI(applicationId);
    var accountUploads = Utilities.GetAccountFilesUploads(applicationId);
    var accountFinancialInvestmentRiskProfile = Utilities.GetAccountInvestmentRiskProfile(applicationId);
    var accountCustodyDetails = Utilities.GetAccountCustodyDetails(applicationId);
    var accountTradingContacts = Utilities.GetAccountTradingContract(applicationId);
    var accountInstructionEmploymentDetails = Utilities.GetAccountInstructionEmploymentDetailModel(applicationId);
    var accountSignatories = Utilities.GetAccountSignatories(applicationId);
    var accountMembers = Utilities.GetAccountMembers(applicationId);
    var accountNextOfKins = Utilities.GetAccountNextOfKins(applicationId);
    var accountSettlementDetails = Utilities.GetAccountSettlementDetail(applicationId);
    var accountAmlResponses = Utilities.GetAccountAMlReponses(applicationId);
    var context = new DBHelper.Schema.DBLAccountOpeningContext();

}

<script src="~/Scripts/appProfile.js"></script>

<style type="text/css">

    th.theader {
        color: #fff;
        background-color: #00a65a !important;
        font-size: 16px;
        padding-top: 4px;
        padding-bottom: 4px;
    }
</style>

<div class="col-md-12">
    <div class="row" style="padding-left:2%; padding-right:2%;">
        <img src="~/Images/pdf_header_logo.png" style="width:300px; height:80px; display:inline;" />
        <img src="~/Images/pdf_header_databank.png" style="width:300px; height:80px; float:right;" />
    </div>
</div>

<div class="col-md-12">
    <div class="card">
        @*<div class="card-header">
                <h3 class="card-title">
                    Application Profile | @Model.AccountName
                </h3>
            </div>*@
        <div class="card-body">


            @{
                if (Model.AccountTypeId <= 3)
                {
                    //single, joint or institutional
                    var firstApplicant = accountMembers.FirstOrDefault();

                    <div class="table-responsive" style="margin-left:0;margin-right:1px;">
                        <table class="table table-striped" style="width:100%;">
                            <tr>
                                <th colspan="2">Account Type</th>
                                <td>@Model.AccountTypeName</td>

                                <th>Investment Type</th>
                                <td colspan="2">@Model.InvestmentTypeName</td>
                            </tr>
                            <tr>
                                <th colspan="2">Expected Account Activity</th>
                                <td colspan="2">@Model.ExpectedAccountActivityName</td>
                                <th>TIN #</th>
                                <td>@Model.TIN</td>
                            </tr>
                            <tr>
                                <th class="theader" colspan="6">First Applicant</th>
                            </tr>

                            <tr>
                                <th>Fullname</th>
                                <td colspan="4">@firstApplicant.TitleName @firstApplicant.Fname @firstApplicant.Othername @firstApplicant.Lname</td>
                            </tr>
                            <tr>
                                <th>Gender</th>
                                <td>@firstApplicant.Gender</td>

                                <th>Nationality</th>
                                <td>@firstApplicant.NationalityName</td>

                                <th>Date of Birth</th>
                                <td>@firstApplicant.DOB</td>
                            </tr>
                            <tr>

                                <th>Place of Birth</th>
                                <td>@firstApplicant.PlaceOfBirth</td>
                                <th>Marital Status</th>
                                <td>@firstApplicant.MaritalStatusName</td>

                                <th>Mothers maiden name</th>
                                <td>@firstApplicant.MothersMaidenName</td>

                            </tr>

                            <tr>

                                @{
                                    if (!string.IsNullOrEmpty(firstApplicant.MaidenName))
                                    {
                                        <th>Maiden name</th>
                                        <td>@firstApplicant.MaidenName</td>
                                    }
                                    <th>Residential Address</th>
                                    <td colspan="3">@firstApplicant.ResidentialAddressFull</td>
                                }
                            </tr>


                            <tr>
                                <th>City</th>
                                <td>@firstApplicant.ResidentialCity</td>
                                <th>Zip Code/GhanaPost Code</th>
                                <td>@firstApplicant.ResidentialZipCode</td>


                                <th>Country</th>
                                <td>@firstApplicant.ResidentialCountryName</td>

                            </tr>

                            <tr>
                                <th>Mailing Address</th>
                                <td>@firstApplicant.MailingAddressFull</td>
                                <th>Applicable Suffix</th>
                                <td>@firstApplicant.SelectWhereApplicableName</td>
                                <th>Telephone</th>
                                <td>@firstApplicant.Telephone</td>

                            </tr>
                            <tr>

                                <th>Mobile</th>
                                <td>@firstApplicant.Mobile</td>
                                <th>Email</th>
                                <td>@firstApplicant.Email</td>
                                <th>Occupation</th>
                                <td>@firstApplicant.Occupation</td>
                            </tr>


                            <tr>
                                <th>ID Type</th>
                                <td>@firstApplicant.IdTypeName</td>
                                <th>ID Number</th>
                                <td>@firstApplicant.IdNumber</td>
                                <th>Issuing Authority </th>
                                <td>@firstApplicant.IssuingAuthority</td>
                            </tr>

                            <tr>
                                <th>ID Issue Date</th>
                                <td>@firstApplicant.IdCardIssueDate</td>
                                <th>ID Expiry Date</th>
                                <td>@firstApplicant.IdCardExpiryDate</td>

                                <th>ID Verification</th>
                                <td id="firstApplicantIdStatus">@firstApplicant.IdCardValidationStatus</td>
                            </tr>

                            <tr>
                                <th>ID Upload</th>
                                <td>
                                    <img src="~/Images/@firstApplicant.IdPath" style="width:100px; height:80px; border:1px groove" /><br />


                                    @{
                                        string IdName = firstApplicant.Lname + " " + firstApplicant.Othername + " " + firstApplicant.Fname;
                                    }
                                    @*<a class="btn btn-xs btn-success" href="javascript:idLookUp('@firstApplicant.IdTypeId','@firstApplicant.IdNumber','@IdName','@firstApplicant.Id','AccMember','loader1','@firstApplicant.IdTypeName','firstApplicantIdStatus')">Lookup</a>
                                        <span id="loader1" style="display:none;">
                                            <img src="~/Images/gifs/3.gif" style="width:20px;height:20px;" />
                                        </span>*@



                                    @{
                                        string downloadFileName = "PhotoId_" + firstApplicant.IdPath;
                                    }
                                    @*<a class="btn btn-success btn-xs" href="~/Images/@firstApplicant.IdPath" title="download file" download="@downloadFileName">
                                            <i class="fa fa-download" style="color:white !important"></i>
                                        </a>*@
                                </td>

                                <th>Signature Upload</th>
                                <td>
                                    <img src="~/Images/@firstApplicant.SignaturePath" style="width:100px; height:80px; border:1px groove" /><br />

                                    @{
                                        downloadFileName = "signature" + firstApplicant.SignaturePath;
                                    }
                                    @*<a class="btn btn-success btn-xs" href="~/Images/@firstApplicant.SignaturePath" title="download file" download="@downloadFileName">
                                            <i class="fa fa-download" style="color:white !important"></i>
                                        </a>*@


                                </td>
                            </tr>
                            @{
                                if (Model.AccountTypeId == 2)
                                {
                                    var secondApplicant = accountMembers.LastOrDefault();


                                    <tr>
                                        <th class="theader" colspan="6">Joint Applicant</th>
                                    </tr>
                                    <tr>
                                        <th>Fullname</th>
                                        <td colspan="4">@secondApplicant.TitleName @secondApplicant.Fname @secondApplicant.Othername @secondApplicant.Lname</td>
                                    </tr>

                                    <tr>
                                        <th>Gender</th>
                                        <td>@secondApplicant.Gender</td>
                                        <th>Nationality</th>
                                        <td>@secondApplicant.NationalityName</td>
                                        <th>Date of Birth</th>
                                        <td>@secondApplicant.DOB</td>
                                    </tr>
                                    <tr>
                                        <th>Place of Birth</th>
                                        <td>@secondApplicant.PlaceOfBirth</td>
                                        <th>Mobile</th>
                                        <td>@secondApplicant.Mobile</td>
                                        <th>Fax</th>
                                        <td>@secondApplicant.Fax</td>
                                    </tr>

                                    <tr>
                                        <th>Email</th>
                                        <td>@secondApplicant.Email</td>
                                        <th>Residential Address</th>
