                                        <th>Occupation</th>
                                        <td>@secondApplicant.Occupation</td>
                                    </tr>

                                    <tr style="page-break-after: always;">
                                        <th>ID Type</th>
                                        <td>@secondApplicant.IdTypeName</td>
                                        <th>ID Number</th>
                                        <td>@secondApplicant.IdNumber</td>
                                        <th>Issuing Authority </th>
                                        <td>@secondApplicant.IssuingAuthority</td>
                                    </tr>

                                    <tr>
                                        <th>ID Issue Date</th>
                                        <td>@secondApplicant.IdCardIssueDate</td>
                                        <th>ID Expiry Date</th>
                                        <td>@secondApplicant.IdCardExpiryDate</td>

                                        <th>ID Verification</th>
                                        <td id="secondApplicantIdStatus">@secondApplicant.IdCardValidationStatus</td>
                                    </tr>


                                    <tr>
                                        <th>ID Upload</th>
                                        <td>
                                            <img src="~/Images/@secondApplicant.IdPath" style="width:100px; height:80px; border:1px groove" /><br />

                                            @{
                                                IdName = secondApplicant.Lname + " " + secondApplicant.Othername + " " + secondApplicant.Fname;
                                            }

                                            @*<a class="btn btn-xs btn-success" href="javascript:idLookUp('@secondApplicant.IdTypeId','@secondApplicant.IdNumber','@IdName','@secondApplicant.Id','AccMember','loader2','@secondApplicant.IdTypeName','secondApplicantIdStatus')">Lookup</a>
                                                <span id="loader2" style="display:none;">
                                                    <img src="~/Images/gifs/3.gif" style="width:20px;height:20px;" />
                                                </span>*@





                                            @{
                                                downloadFileName = "PhotoId_" + secondApplicant.IdPath;
                                            }
                                            @*<a class="btn btn-success btn-xs" href="~/Images/@secondApplicant.IdPath" title="download file" download="@downloadFileName">
                                                    <i class="fa fa-download" style="color:white !important"></i>
                                                </a>*@

                                        </td>

                                        <th>Signature Upload</th>
                                        <td>
                                            <img src="~/Images/@secondApplicant.SignaturePath" style="width:100px; height:80px; border:1px groove" /><br />

                                            @{
                                                downloadFileName = "signature" + secondApplicant.SignaturePath;
                                            }
                                            @*<a class="btn btn-success btn-xs" href="~/Images/@secondApplicant.SignaturePath" title="download file" download="@downloadFileName">
                                                    <i class="fa fa-download" style="color:white !important"></i>
                                                </a>*@


                                        </td>
                                    </tr>
                                }







                                else if (Model.AccountTypeId == 3)
                                {
                                    var itfApplicant = accountMembers.LastOrDefault();

                                    <tr>
                                        <th class="theader" colspan="6">ITF Applicant</th>
                                    </tr>
                                    <tr>
                                        <th>Fullname</th>
                                        <td colspan="4">@itfApplicant.TitleName @itfApplicant.Fname @itfApplicant.Othername @itfApplicant.Lname</td>
                                    </tr>
                                    <tr>
                                        <th>Gender</th>
                                        <td>@itfApplicant.Gender</td>
                                        <th>Nationality</th>
                                        <td>@itfApplicant.NationalityName</td>
                                        <th>Date of Birth</th>
                                        <td>@itfApplicant.DOB</td>
                                    </tr>
                                    <tr>
                                        <th>Place of Birth</th>
                                        <td colspan="5">@itfApplicant.PlaceOfBirth</td>
                                    </tr>

                                    <tr style="page-break-after: always;">
                                        <th>ID Type</th>
                                        <td>@itfApplicant.IdTypeName</td>
                                        <th>ID Number</th>
                                        <td>@itfApplicant.IdNumber</td>
                                        <th>Issuing Authority </th>
                                        <td>@itfApplicant.IssuingAuthority</td>
                                    </tr>


                                    <tr>
                                        <th>ID Issue Date</th>
                                        <td>@itfApplicant.IdCardIssueDate</td>
                                        <th>ID Expiry Date</th>
                                        <td>@itfApplicant.IdCardExpiryDate</td>
                                        <th>ID Upload</th>
                                        <td>
                                            <div style="page-break-inside: avoid">
                                                <img src="~/Images/@itfApplicant.IdPath" style="width:100px; height:80px; border:1px groove; page-break-inside:avoid;" />
                                            </div>

                                            @{
                                                IdName = itfApplicant.Lname + " " + itfApplicant.Othername + " " + itfApplicant.Fname;
                                            }






                                            @{
                                                downloadFileName = "PhotoId_" + itfApplicant.IdPath;
                                            }

                                        </td>

                                    </tr>

                                    <tr>
                                        <td colspan="4"></td>
                                        <th>ID Verification</th>
                                        <td id="itfApplicantIdStatus">@itfApplicant.IdCardValidationStatus</td>

                                    </tr>
                                }



                                <tr>
                                    <th class="theader" colspan="6">Next Of Kins Details</th>
                                </tr>
                                if (accountNextOfKins.Count > 1)
                                {
                                    <tr>
                                        <th colspan="6">Next of Kin 1</th>
                                    </tr>
                                }
                                var nextOfKin1 = accountNextOfKins.FirstOrDefault();
                                <tr>
                                    <th>Name</th>
                                    <td>@nextOfKin1.Name</td>
                                    <th>Telephone</th>
                                    <td>@nextOfKin1.Telephone</td>
                                    <th>Mobile</th>
                                    <td>@nextOfKin1.Mobile</td>
                                </tr>
                                <tr>
                                    <th>Fax</th>
                                    <td>@nextOfKin1.Fax</td>
                                    <th>Relation to the Acc. Holder</th>
                                    <td>@nextOfKin1.RelationToAccount</td>
                                    <th>E-mail address</th>
                                    <td>@nextOfKin1.Email</td>
                                </tr>

                                <tr>
                                    <th>Mailing Address</th>
                                    <td colspan="5">@nextOfKin1.MailingAddress</td>
                                </tr>
                                if (accountNextOfKins.Count > 1)
                                {
                                    var nextOfKin2 = accountNextOfKins.LastOrDefault();
                                    <tr>
                                        <th colspan="6">Next of Kin 2</th>
                                    </tr>

                                    <tr>
                                        <th>Name</th>
                                        <td>@nextOfKin2.Name</td>
                                        <th>Telephone</th>
                                        <td>@nextOfKin2.Telephone</td>
                                        <th>Mobile</th>
                                        <td>@nextOfKin2.Mobile</td>
                                    </tr>
                                    <tr>
                                        <th>Fax</th>
                                        <td>@nextOfKin2.Fax</td>
                                        <th>Relation to the Acc. Holder</th>
                                        <td>@nextOfKin2.RelationToAccount</td>
                                        <th>E-mail address</th>
                                        <td>@nextOfKin2.Email</td>
                                    </tr>

                                    <tr>
                                        <th>Mailing Address</th>
                                        <td colspan="5">@nextOfKin2.MailingAddress</td>
                                    </tr>
                                }

                                if (accountAuthorisedPersons.Any())
                                {
                                    <tr>
                                        <th class="theader" colspan="6">
                                            Authorised Person other than Account Holder(s) to Deal on the Account
                                        </th>
                                    </tr>
                                    var authorisedPerson = accountAuthorisedPersons.FirstOrDefault();
                                    <tr>
                                        <th>Name</th>
                                        <td>@authorisedPerson.Name</td>
                                        <th>Telephone</th>
                                        <td>@authorisedPerson.Tel</td>
                                        <th>Mobile</th>
                                        <td>@authorisedPerson.Mobile</td>
                                    </tr>

                                    <tr>
                                        <th>Fax</th>
                                        <td>@authorisedPerson.Fax</td>
                                        <th>Relation to acc. holder</th>
                                        <td>@authorisedPerson.RelationToAccountHolder</td>
                                        <th>Email</th>
                                        <td>@authorisedPerson.Email</td>
                                    </tr>

                                    <tr>
                                        <th>Mailing address</th>
                                        <td>@authorisedPerson.MailingAddress</td>
                                        <th>City</th>
                                        <td>@authorisedPerson.City</td>
                                        <th>Country</th>
                                        <td>@authorisedPerson.CountryName</td>
                                    </tr>


                                    <tr>
                                        <th>ID Type</th>
                                        <td>@authorisedPerson.IdTypeName</td>
                                        <th>ID Number</th>
                                        <td>@authorisedPerson.IdNumber</td>
                                        <th>Issuing Authority </th>
                                        <td>@authorisedPerson.IdIssueAuthority</td>
                                    </tr>

                                    <tr>
                                        <th>ID Issue Date</th>
                                        <td>@authorisedPerson.IssueDate</td>
                                        <th>ID Expiry Date</th>
                                        <td>@authorisedPerson.IDExpiryDate</td>
                                        <th>ID Upload</th>
                                        <td>
                                            @{
                                                if (!string.IsNullOrEmpty(authorisedPerson.IdPath))
                                                {
                                                    <img src="~/Images/@authorisedPerson.IdPath" style="width:100px; height:80px; border:1px groove" /><br />


                                                    IdName = authorisedPerson.Name;


                                                    @*<a class="btn btn-xs btn-success" href="javascript:idLookUp('@authorisedPerson.IdType','@authorisedPerson.IdNumber','@IdName','@authorisedPerson.Id','AuthPerson','loader4','@authorisedPerson.IdTypeName','authPersonIndividualIdStatus')">Lookup</a>
                                                        <span id="loader4" style="display:none;">
                                                            <img src="~/Images/gifs/3.gif" style="width:20px;height:20px;" />
                                                        </span>*@







                                                    downloadFileName = "PhotoId_" + authorisedPerson.IdPath;

                                                    @*<a class="btn btn-success btn-xs" href="~/Images/@authorisedPerson.IdPath" title="download file" download="@downloadFileName">
                                                            <i class="fa fa-download" style="color:white !important"></i>
                                                        </a>*@


                                                }
                                            }

                                        </td>

                                    </tr>
                                    <tr>
                                        <td colspan="4"></td>
                                        <th>ID Verification</th>
                                        <td id="authPersonIndividualIdStatus">@authorisedPerson.IdCardValidationStatus</td>

                                    </tr>

                                }

                                <tr>
                                    <th colspan="6" style="height:30px;"></th>
                                </tr>


