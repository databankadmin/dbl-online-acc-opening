                                    <th>Account Number</th>
                                    <td>@accountSettlementDetails.AccountNumber</td>
                                    <th>Bank</th>
                                    <td>@accountSettlementDetails.BankName</td>
                                </tr>

                                <tr>
                                    <th>Branch</th>
                                    <td>@accountSettlementDetails.Branch</td>
                                    <th>Swift Code</th>
                                    <td colspan="3">@accountSettlementDetails.SwiftCode</td>
                                </tr>

                                <tr>
                                    <th class="theader" colspan="6">
                                        Instructions and Employment Details

                                    </th>
                                </tr>
                                <tr>
                                    <th>Mode of Instructions</th>
                                    <td>@accountInstructionEmploymentDetails.ModeOfInstructionName</td>

                                    <th>Mode of Notifications</th>
                                    <td>@accountInstructionEmploymentDetails.ModeOfNotificationName</td>
                                    <th>Source of Funds</th>
                                    <td>@accountInstructionEmploymentDetails.SourceOfIncomeName</td>
                                </tr>


                                <tr>
                                    <th>Employment Status</th>
                                    <td>@accountInstructionEmploymentDetails.EmploymentStatusName</td>

                                    <th>Previous Occupation</th>
                                    <td>@accountInstructionEmploymentDetails.PrevOccupation</td>
                                    <th>Previous Employer</th>
                                    <td>@accountInstructionEmploymentDetails.PrevEmployer</td>
                                </tr>


                                <tr>
                                    <th>Current Occupation</th>
                                    <td>@accountInstructionEmploymentDetails.CurrentOccupation</td>

                                    <th>Current Employer</th>
                                    <td>@accountInstructionEmploymentDetails.CurrentEmployer</td>
                                    <th>Current Employer Address</th>
                                    <td>@accountInstructionEmploymentDetails.CurrentEmployerAddress</td>
                                </tr>
                                <tr>
                                    <th>Employment Dates: (From)</th>
                                    <td>@accountInstructionEmploymentDetails.EmploymentDateFrom</td>

                                    <th>Employment Dates: (To)</th>
                                    <td>@accountInstructionEmploymentDetails.EmploymentDateTo</td>
                                    <th>Total years of employment(in years)</th>
                                    <td>@accountInstructionEmploymentDetails.YearsOfEmployment</td>

                                </tr>


                                <tr>
                                    <th class="theader" colspan="6">
                                        Financial, Investment and Risk Profile
                                    </th>
                                </tr>
                                <tr>
                                    <th>Approx. Annual Income(GHS)</th>
                                    <td>@accountFinancialInvestmentRiskProfile.ApproximateAnnualIncomeName</td>
                                    <th>Net Worth(GHS)</th>
                                    <td>@accountFinancialInvestmentRiskProfile.NetWorthName</td>
                                    <th>Investment Horizon</th>
                                    <td>@accountFinancialInvestmentRiskProfile.InvestmentHorizonName</td>
                                </tr>

                                <tr>
                                    <th>Objectives</th>
                                    <td>@accountFinancialInvestmentRiskProfile.ObjectiveName</td>
                                    <th>Investment Knowledge</th>
                                    <td>@accountFinancialInvestmentRiskProfile.InvestmentKnowledgeName</td>
                                    <th>Risk Tolerance</th>
                                    <td>@accountFinancialInvestmentRiskProfile.RiskToleranceName</td>
                                </tr>

                                <tr>
                                    <th colspan="2">Online Trading Facility</th>
                                    <td>@accountFinancialInvestmentRiskProfile.OnlineTradingFacility</td>
                                    <th colspan="2">Frequency of Account Statements</th>
