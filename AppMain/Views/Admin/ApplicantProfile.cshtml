@using AppModels
@using AppUtils
@model AppModels.AccountBasicModel
@{
    ViewBag.Title = "Applicant Profile | " + Model.AccountName;
    Layout = "~/Views/Shared/_Admin.cshtml";
    Guid applicationId = Guid.Parse(ViewBag.applicationId.ToString());

    var accountAuthorisedPersons = Utilities.GetAccountAuthorisedPersons(applicationId);
    var accountETI = Utilities.GetAccountETI(applicationId);
    var accountUploads = Utilities.GetAccountFilesUploads(applicationId);
    var accountFinancialInvestmentRiskProfile = Utilities.GetAccountInvestmentRiskProfile(applicationId);
    var accountCustodyDetails = Utilities.GetAccountCustodyDetails(applicationId);
    var accountTradingContacts = Utilities.GetAccountTradingContract(applicationId);
    var accountInstructionEmploymentDetails = Utilities.GetAccountInstructionEmploymentDetailModel(applicationId);
    var accountSignatories = Utilities.GetAccountSignatories(applicationId);
    var accountMembers = Utilities.GetAccountMembers(applicationId);
    var accountNextOfKins = Utilities.GetAccountNextOfKins(applicationId);
    var accountSettlementDetails = Utilities.GetAccountSettlementDetail(applicationId);
    var context = new DBHelper.Schema.DBLAccountOpeningContext();
   // var accountActivity = context.ExpectedAccountActivities.Find(Model.ExpectedAccountActivityId.Value);

}

<style type="text/css">
    .nav-pills .nav-link.active, .nav-pills .show > .nav-link {
        color: #fff;
        background-color: #00a65a;
    }
    th.theader {
        color: #fff;
        background-color: #00a65a !important;
        font-size:16px; padding-top:4px; padding-bottom:4px; width:100%;
    }
</style>


<div class="col-md-12">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                Application Profile | @Model.AccountName
            </h3>
        </div>
        <div class="card-body">

            <ul class="nav nav-pills" id="myTab">
                <li class="nav-item"><a class="nav-link active" href="#basic" data-toggle="tab">Basic Profile</a></li>
                <li class="nav-item"><a class="nav-link" href="#files" data-toggle="tab">File Uploads</a></li>

                <li class="nav-item"><a class="nav-link" href="#aml" data-toggle="tab">AML Profile</a></li>

                <li class="nav-item"><a class="nav-link" href="#eti" data-toggle="tab">ETI Details</a></li>


            </ul>


            <div class="tab-content">
                <br />
                <div class="tab-pane active" id="basic">
                    <div class="col-col-12 invoice-col">
                        @{
                            if (Model.AccountTypeId <= 3)
                            {
                                //single, joint or institutional
                                var firstApplicant = accountMembers.FirstOrDefault();

                                <div class="table-responsive">
                                    <table class="table" style="width:100%;">
                                        <tr>
                                            <th>Account Type</th>
                                            <td>@Model.AccountTypeName</td>

                                            <th>Investment Type</th>
                                            <td>@Model.InvestmentTypeName</td>
                                        </tr>
                                        <tr>
                                            <th>Expected Account Activity</th>
                                            <td>@Model.ExpectedAccountActivityName</td>
                                            <th>TIN #</th>
                                            <td>@Model.TIN</td>
                                        </tr>
                                        <tr>
                                            <th class="theader" colspan="6">First Applicant</th>
                                        </tr>

                                        <tr>
                                            <th>Fullname</th>
                                            <td colspan="4">@firstApplicant.TitleName @firstApplicant.Fname @firstApplicant.Othername @firstApplicant.Lname</td>
                                        </tr>
                                        <tr>
                                            <th>Gender</th>
                                            <td>@firstApplicant.Gender</td>

                                            <th>Nationality</th>
                                            <td>@firstApplicant.NationalityName</td>

                                            <th>Date of Birth</th>
                                            <td>@firstApplicant.DOB</td>
                                        </tr>
                                        <tr>

                                            <th>Place of Birth</th>
                                            <td>@firstApplicant.PlaceOfBirth</td>
                                            <th>Marital Status</th>
                                            <td>@firstApplicant.MaritalStatusName</td>

                                            <th>Mothers maiden name</th>
                                            <td>@firstApplicant.MothersMaidenName</td>

                                        </tr>

                                        <tr>

                                            @{
                                                if (!string.IsNullOrEmpty(firstApplicant.MaidenName))
                                                {
                                                    <th>Maiden name</th>
                                                    <td>@firstApplicant.MaidenName</td>
                                                }
                                                <th>Residential Address</th>
                                                <td colspan="3">@firstApplicant.ResidentialAddressFull</td>
                                            }
                                        </tr>


                                        <tr>
                                            <th>City</th>
                                            <td>@firstApplicant.ResidentialCity</td>
                                            <th>Zip Code/GhanaPost Code</th>
                                            <td>@firstApplicant.ResidentialZipCode</td>


                                            <th>Country</th>
                                            <td>@firstApplicant.ResidentialCountryName</td>

                                        </tr>

                                        <tr>
                                            <th>Mailing Address</th>
                                            <td>@firstApplicant.MailingAddressFull</td>
                                            <th>Applicable Suffix</th>
                                            <td>@firstApplicant.SelectWhereApplicableName</td>
                                            <th>Telephone</th>
                                            <td>@firstApplicant.Telephone</td>

                                        </tr>
                                        <tr>

                                            <th>Mobile</th>
                                            <td>@firstApplicant.Mobile</td>
                                            <th>Email</th>
                                            <td>@firstApplicant.Email</td>
                                            <th>Occupation</th>
                                            <td>@firstApplicant.Occupation</td>
                                        </tr>


                                        <tr>
                                            <th>ID Type</th>
                                            <td>@firstApplicant.IdTypeName</td>
                                            <th>ID Number</th>
                                            <td>@firstApplicant.IdNumber</td>
                                            <th>Issuing Authority </th>
                                            <td>@firstApplicant.IssuingAuthority</td>
                                        </tr>

                                        <tr>
                                            <th>ID Issue Date</th>
                                            <td>@firstApplicant.IdCardIssueDate</td>
                                            <th>ID Expiry Date</th>
                                            <td>@firstApplicant.IdCardExpiryDate</td>
                                        </tr>

                                        <tr>
                                            <th>ID Upload</th>
                                            <td>
                                                <img src="~/Images/@firstApplicant.IdPath" style="width:150px; height:120px; border:1px groove" /><br />
                                                <a class="btn btn-xs btn-success" href="">Lookup on GVIVE</a>
                                            </td>

                                            <th>Signature Upload</th>
                                            <td>
                                                <img src="~/Images/@firstApplicant.SignaturePath" style="width:150px; height:120px; border:1px groove" /><br />
                                            </td>
                                        </tr>

                                        @{
                                            if (Model.AccountTypeId == 2)
                                            {
                                                var secondApplicant = accountMembers.LastOrDefault();
                                                <tr>
                                                    <th class="theader" colspan="6">Joint Applicant</th>
                                                </tr>
                                                <tr>
                                                    <th>Fullname</th>
                                                    <td colspan="4">@secondApplicant.TitleName @secondApplicant.Fname @secondApplicant.Othername @secondApplicant.Lname</td>
                                                </tr>

                                                <tr>
                                                    <th>Gender</th>
                                                    <td>@secondApplicant.Gender</td>
                                                    <th>Nationality</th>
                                                    <td>@secondApplicant.NationalityName</td>
                                                    <th>Date of Birth</th>
                                                    <td>@secondApplicant.DOB</td>
                                                </tr>
                                                <tr>
                                                    <th>Place of Birth</th>
                                                    <td>@secondApplicant.PlaceOfBirth</td>
                                                    <th>Mobile</th>
                                                    <td>@secondApplicant.Mobile</td>
                                                    <th>Fax</th>
                                                    <td>@secondApplicant.Fax</td>
                                                </tr>

                                                <tr>
                                                    <th>Email</th>
                                                    <td>@secondApplicant.Email</td>
                                                    <th>Residential Address</th>
                                                    <td>@secondApplicant.ResidentialAddressFull</td>
                                                    <th>Occupation</th>
                                                    <td>@secondApplicant.Occupation</td>
                                                </tr>

                                                <tr>
                                                    <th>ID Type</th>
                                                    <td>@secondApplicant.IdTypeName</td>
                                                    <th>ID Number</th>
                                                    <td>@secondApplicant.IdNumber</td>
                                                    <th>Issuing Authority </th>
                                                    <td>@secondApplicant.IssuingAuthority</td>
                                                </tr>

                                                <tr>
                                                    <th>ID Issue Date</th>
                                                    <td>@secondApplicant.IdCardIssueDate</td>
                                                    <th>ID Expiry Date</th>
                                                    <td>@secondApplicant.IdCardExpiryDate</td>
                                                </tr>


                                                <tr>
                                                    <th>ID Upload</th>
                                                    <td>
                                                        <img src="~/Images/@secondApplicant.IdPath" style="width:150px; height:120px; border:1px groove" /><br />
                                                        <a class="btn btn-xs btn-success" href="">Lookup on GVIVE</a>
                                                    </td>

                                                    <th>Signature Upload</th>
                                                    <td>
                                                        <img src="~/Images/@secondApplicant.SignaturePath" style="width:150px; height:120px; border:1px groove" /><br />
                                                    </td>
                                                </tr>
                                            }







                                            else if (Model.AccountTypeId == 3)
                                            {
                                                var itfApplicant = accountMembers.LastOrDefault();

                                                <tr>
                                                    <th class="theader" colspan="6">ITF Applicant</th>
                                                </tr>
                                                <tr>
                                                    <th>Fullname</th>
                                                    <td colspan="4">@itfApplicant.TitleName @itfApplicant.Fname @itfApplicant.Othername @itfApplicant.Lname</td>
                                                </tr>
                                                <tr>
                                                    <th>Gender</th>
                                                    <td>@itfApplicant.Gender</td>
                                                    <th>Nationality</th>
                                                    <td>@itfApplicant.NationalityName</td>
                                                    <th>Date of Birth</th>
                                                    <td>@itfApplicant.DOB</td>
                                                </tr>
                                                <tr>
                                                    <th>Place of Birth</th>
                                                    <td colspan="5">@itfApplicant.PlaceOfBirth</td>
                                                </tr>

                                                <tr>
                                                    <th>ID Type</th>
                                                    <td>@itfApplicant.IdTypeName</td>
                                                    <th>ID Number</th>
                                                    <td>@itfApplicant.IdNumber</td>
                                                    <th>Issuing Authority </th>
                                                    <td>@itfApplicant.IssuingAuthority</td>
                                                </tr>

                                                <tr>
                                                    <th>ID Issue Date</th>
                                                    <td>@itfApplicant.IdCardIssueDate</td>
                                                    <th>ID Expiry Date</th>
                                                    <td>@itfApplicant.IdCardExpiryDate</td>
                                                    <th>ID Upload</th>
                                                    <td>
                                                        <img src="~/Images/@itfApplicant.IdPath" style="width:150px; height:120px; border:1px groove" /><br />
                                                        <a class="btn btn-xs btn-success" href="">Lookup on GVIVE</a>
                                                    </td>

                                                </tr>

                                            }



                                            <tr>
                                                <th class="theader" colspan="6">Next Of Kins Details</th>
                                            </tr>
                                            if (accountNextOfKins.Count > 1)
                                            {
                                                <tr>
                                                    <th colspan="6">Next of Kin 1</th>
                                                </tr>
                                            }
                                            var nextOfKin1 = accountNextOfKins.FirstOrDefault();
                                            <tr>
                                                <th>Name</th>
                                                <td>@nextOfKin1.Name</td>
                                                <th>Telephone</th>
                                                <td>@nextOfKin1.Telephone</td>
                                                <th>Mobile</th>
                                                <td>@nextOfKin1.Mobile</td>
                                            </tr>
                                            <tr>
                                                <th>Fax</th>
                                                <td>@nextOfKin1.Fax</td>
                                                <th>Relation to the Acc. Holder</th>
                                                <td>@nextOfKin1.RelationToAccount</td>
                                                <th>E-mail address</th>
                                                <td>@nextOfKin1.Email</td>
                                            </tr>

                                            <tr>
                                                <th>Mailing Address</th>
                                                <td colspan="5">@nextOfKin1.MailingAddress</td>
                                            </tr>
                                            if (accountNextOfKins.Count > 1)
                                            {
                                                var nextOfKin2 = accountNextOfKins.LastOrDefault();
                                                <tr>
                                                    <th colspan="6">Next of Kin 2</th>
                                                </tr>

                                                <tr>
                                                    <th>Name</th>
                                                    <td>@nextOfKin2.Name</td>
                                                    <th>Telephone</th>
                                                    <td>@nextOfKin2.Telephone</td>
                                                    <th>Mobile</th>
                                                    <td>@nextOfKin2.Mobile</td>
                                                </tr>
                                                <tr>
                                                    <th>Fax</th>
                                                    <td>@nextOfKin2.Fax</td>
                                                    <th>Relation to the Acc. Holder</th>
                                                    <td>@nextOfKin2.RelationToAccount</td>
                                                    <th>E-mail address</th>
                                                    <td>@nextOfKin2.Email</td>
                                                </tr>

                                                <tr>
                                                    <th>Mailing Address</th>
                                                    <td colspan="5">@nextOfKin2.MailingAddress</td>
                                                </tr>
                                            }


                                            <tr>
                                                <th class="theader" colspan="6">
                                                    Authorised Person other than Account Holder(s) to Deal on the Account
                                                </th>
                                            </tr>
                                            var authorisedPerson = accountAuthorisedPersons.FirstOrDefault();
                                            <tr>
                                                <th>Name</th>
                                                <td>@authorisedPerson.Name</td>
                                                <th>Telephone</th>
                                                <td>@authorisedPerson.Tel</td>
                                                <th>Mobile</th>
                                                <td>@authorisedPerson.Mobile</td>
                                            </tr>

                                            <tr>
                                                <th>Fax</th>
                                                <td>@authorisedPerson.Fax</td>
                                                <th>Relation to account holder</th>
                                                <td>@authorisedPerson.RelationToAccountHolder</td>
                                                <th>Email</th>
                                                <td>@authorisedPerson.Email</td>
                                            </tr>

                                            <tr>
                                                <th>Mailing address</th>
                                                <td>@authorisedPerson.MailingAddress</td>
                                                <th>City</th>
                                                <td>@authorisedPerson.City</td>
                                                <th>Country</th>
                                                <td>@authorisedPerson.CountryName</td>
                                            </tr>


                                            <tr>
                                                <th>ID Type</th>
                                                <td>@authorisedPerson.IdTypeName</td>
                                                <th>ID Number</th>
                                                <td>@authorisedPerson.IdNumber</td>
                                                <th>Issuing Authority </th>
                                                <td>@authorisedPerson.IdIssueAuthority</td>
                                            </tr>

                                            <tr>
                                                <th>ID Issue Date</th>
                                                <td>@authorisedPerson.IssueDate</td>
                                                <th>ID Expiry Date</th>
                                                <td>@authorisedPerson.IDExpiryDate</td>
                                                <th>ID Upload</th>
                                                <td>
                                                    <img src="~/Images/@authorisedPerson.IdPath" style="width:150px; height:120px; border:1px groove" /><br />
                                                    <a class="btn btn-xs btn-success" href="">Lookup on GVIVE</a>
                                                </td>

                                            </tr>

                                            <tr>
                                                <th class="theader" colspan="6">
                                                    Settlement Details
                                                </th>
                                            </tr>
                                            <tr>
                                                <th>Account Name</th>
                                                <td>@accountSettlementDetails.AccountName</td>
                                                <th>Account Number</th>
                                                <td>@accountSettlementDetails.AccountNumber</td>
                                                <th>Bank</th>
                                                <td>@accountSettlementDetails.BankName</td>
                                            </tr>
                                           
                                            <tr>
                                                <th>Branch</th>
                                                <td>@accountSettlementDetails.Branch</td>
                                                <th>Swift Code</th>
                                                <td>@accountSettlementDetails.SwiftCode</td>
                                            </tr>

                                        }
                                    </table>
                                </div>

                                            }

                                            else
                                            {
                                                //institutional
                                            }
                        }
                    </div>
                </div>

                <div class="tab-pane" id="files">files...</div>
                <div class="tab-pane" id="aml">aml...</div>
                <div class="tab-pane" id="eti">eti...</div>
            </div>
            </div>
    </div>
</div>

