@using DBHelper.Schema
@{
    ViewBag.Title = "Settings";
    Layout = "~/Views/Shared/_Admin.cshtml";
    var context = new DBLAccountOpeningContext();
    var banks = context.Banks.Where(x => x.IsActive).ToList();
}




<div class="col-md-12">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                Settings
            </h3>
        </div>
        <div class="card-body">

            <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <a class="nav-link active" id="pills-home-tab" data-toggle="pill" href="#pills-home" role="tab" aria-controls="pills-home" aria-selected="true">Banks</a>
                </li>
                @*<li class="nav-item" role="presentation">
                        <a class="nav-link" id="pills-profile-tab" data-toggle="pill" href="#pills-profile" role="tab" aria-controls="pills-profile" aria-selected="false">Profile</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="pills-contact-tab" data-toggle="pill" href="#pills-contact" role="tab" aria-controls="pills-contact" aria-selected="false">Contact</a>
                    </li>*@
            </ul>
            <div class="tab-content" id="pills-tabContent">
                <div class="tab-pane fade show active" id="pills-home" role="tabpanel" aria-labelledby="pills-home-tab">


                    <div class="table-responsive">
                        <a class="btn btn-xs btn-primary" title="add" onclick="javascript:add('1')" style="color:white"> <i class="fa fa-plus"></i> New Bank</a>

                        <table class="table table-bordered table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    foreach (var item in banks.OrderBy(x => x.Name))
                                    {
                                        string encName = AppUtils.Utilities.EncodeBase64(item.Name);
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>
                                                @{

                                                    <a style="color: blue;" title="edit" href="#" onclick="javascript:editItem('@encName','@item.Id','1')"><i class="fa fa-edit"></i></a>
                                                    <a style="color: red;" title="delete" href="#" onclick="javascript:confirmDelete('1','@encName', '@item.Id')"><i class="fa fa-trash"></i></a>


                                                }
                                            </td>
                                        </tr>
                                    }

                                }
                            </tbody>
                        </table>
                    </div>

                </div>
                <div class="tab-pane fade" id="pills-profile" role="tabpanel" aria-labelledby="pills-profile-tab">content 2</div>
                <div class="tab-pane fade" id="pills-contact" role="tabpanel" aria-labelledby="pills-contact-tab">content 3</div>
            </div>

        </div>
    </div>
</div>



<div class="modal fade" id="addModal">
    <form method="post" action="@Url.Action("AddLoopUpItem", "Admin")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="addMsg"></h4>
                    <input type="hidden" name="addOrderId" id="addOrderId" />
                </div>
                <div class="modal-body">

                    <input type="text" name="addName" id="addName" placeholder="name" required class="form-control" /><br />
                    <input style="display:none;" type="file" name="ImageUrl" id="ImageUrl" class="btn btn-sm" onchange="javascript: validateUploadImageOnly('staffFile')" />

                    @*<textarea name="desc" id="desc" class="form-control" placeholder="description"></textarea>*@
                </div>
                <div class="modal-footer">
                    <input type="submit" value="Add" class="btn btn-primary" />
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>

                </div>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->

    </form>

</div>








<div class="modal fade" id="editModal">
    <form method="post" action="@Url.Action("EditLookUpItem", "Admin")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="editMsg"></h4>
                    <input type="hidden" name="editOrderId" id="editOrderId" />
                    <input type="hidden" name="editItemId" id="editItemId" />
                </div>
                <div class="modal-body">

                    <input type="text" name="editName" id="editName" placeholder="name" required class="form-control" /><br />
                    <input style="display:none;" type="file" name="EditImageUrl" id="EditImageUrl" class="btn btn-sm" onchange="javascript: validateUploadImageOnly('staffFile')" />

                </div>
                <div class="modal-footer">
                    <input type="submit" value="Update" class="btn btn-primary" />
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>

                </div>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->

    </form>

</div>





