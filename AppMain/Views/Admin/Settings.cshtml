     function confirmDelete(order,accNum, accId) {
        bootbox.dialog(
            {
                title: "Confirm Action",
                message: "Delete record?<br/>" +atob(accNum),
                buttons: {
                    success: {
                        label: "OK",
                        className: "btn-success",
                        callback: function () {
                            document.location.href = "@Url.Action("DeleteItem", "Admin")?order=" + order + "&itemId=" + accId;
                        }
                    },
                    main: {
                        label: "Cancel",
                        className: "btn-danger",
                        callback: function() {

                        }
                    }

                }
            });
    }


