@using AppModels
@using AppUtils
@using AppMain.Providers


@model AppModels.AccountBasicModel
@{
    ViewBag.Title = "Applicant Profile | " + Model.AccountName;
    Layout = "~/Views/Shared/_Admin.cshtml";
    Guid applicationId = Guid.Parse(ViewBag.applicationId.ToString());

    var accountAuthorisedPersons = Utilities.GetAccountAuthorisedPersons(applicationId);
    var accountETI = Utilities.GetAccountETI(applicationId);
    var accountUploads = Utilities.GetAccountFilesUploads(applicationId);
    var accountFinancialInvestmentRiskProfile = Utilities.GetAccountInvestmentRiskProfile(applicationId);
    var accountCustodyDetails = Utilities.GetAccountCustodyDetails(applicationId);
    var accountTradingContacts = Utilities.GetAccountTradingContract(applicationId);
    var accountInstructionEmploymentDetails = Utilities.GetAccountInstructionEmploymentDetailModel(applicationId);
    var accountSignatories = Utilities.GetAccountSignatories(applicationId);
    var accountMembers = Utilities.GetAccountMembers(applicationId);
    var accountNextOfKins = Utilities.GetAccountNextOfKins(applicationId);
    var accountBeneficiaries = Utilities.GetBeneficiaries(applicationId);
    var accountSettlementDetails = Utilities.GetAccountSettlementDetail(applicationId);
    var accountAmlResponses = Utilities.GetAccountAMlReponses(applicationId);
    var context = new DBHelper.Schema.DBLAccountOpeningContext();
    // var accountActivity = context.ExpectedAccountActivities.Find(Model.ExpectedAccountActivityId.Value);
    // var acc = context.Accounts.Find(Model.Id);
    var checkListItems = context.AccountCheckLists.Where(x => x.AccountId == applicationId);

    bool allowCSDFormGenerate = string.IsNullOrEmpty(ViewBag.staffSign) ? false : true;
}
<script src="~/Scripts/appProfile.js"></script>


<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote.min.js"></script>
<style type="text/css">
    .nav-pills .nav-link.active, .nav-pills .show > .nav-link {
        color: #fff;
        background-color: #00a65a;
    }

    th.theader {
        color: #fff;
        background-color: #00a65a !important;
        font-size: 16px;
        padding-top: 4px;
        padding-bottom: 4px;
        width: 100%;
    }
</style>


<div class="col-md-12">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                Application Profile | @Model.AccountName |
                @{
                    if (Model.StatusId == 1)
                    {
                        <span class="badge badge-info">@Model.StatusName</span>
                    }
                    else if (Model.StatusId == 2)
                    {
                        <span class="badge badge-success">@Model.StatusName</span>
                    }
                    else
                    {
                        <span class="badge badge-danger">@Model.StatusName</span>
                    }

                    if (!string.IsNullOrEmpty(Model.BackConnectAccountNumber))
                    {
                        <span> | @Model.BackConnectAccountNumber</span>
                    }
                }

            </h3>
        </div>
        <div class="card-body">

            <ul class="nav nav-pills" id="myTab">
                <li class="nav-item"><a class="nav-link active" href="#basic" data-toggle="tab">Basic Profile</a></li>
                <li class="nav-item"><a class="nav-link" href="#files" data-toggle="tab">File Uploads</a></li>

                <li class="nav-item"><a class="nav-link" href="#aml" data-toggle="tab">AML Profile</a></li>

                <li class="nav-item"><a class="nav-link" href="#eti" data-toggle="tab">Email Indemnity</a></li>
                @{
                    if (checkListItems != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="#chcklist" data-toggle="tab">Account Check List</a></li>

                    }
                }

            </ul>


