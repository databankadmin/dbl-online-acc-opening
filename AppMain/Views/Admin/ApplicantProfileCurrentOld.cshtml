<div class="modal fade" id="reviewAccModal">

    <form method="post" action="@Url.Action("ReviewSuccessfully", "Admin")">
        @Html.AntiForgeryToken()

        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">Check list items</h3>
                </div>
                <div class="modal-body">
                    <div class="card-body">
                        <p id="msg1"></p>
                        <p id="msg2"></p>
                        <input type="hidden" name="_ref" id="_ref" value="@Model.Id" />
                        <table class="table table-striped table-condensed">
                            @{
                                foreach (var item in context.CheckListItems.OrderBy(x => x.Id))
                                {
                            <tr>
                                <td>
                                    <label style="font-weight:500; font-style:normal;">
                                        <input type="checkbox" name="checkList[]" value="@item.Id" id="@Guid.NewGuid()" />

                                        @item.Name
                                    </label>
                                </td>


                            </tr>
                                    
                                }
                            }
                        </table>
                      
                       

                    </div>


                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-info">Send</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>
                </div>
            </div><!-- /.modal-content -->
        </div>

    </form>
</div>


<div class="modal fade" id="uploadStaffSignatureModal">

    <form method="post" action="@Url.Action("UploadStaffSignature", "Admin")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">Upload your signature file</h3>
                </div>
                <div class="modal-body">
                    <div class="card-body">
                        <p id="msg1"></p>
                        <p id="msg2"></p>
                        <input type="hidden" name="appId" id="appId" value="@applicationId"/>
<input type="file"  name="staffSign" id="staffSign" required onchange="javascript:validateUploadImageOnly('staffSign')"/>                       

                    </div>


                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-info">Save</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>
                </div>
            </div><!-- /.modal-content -->
        </div>

    </form>
</div>






<script type="text/javascript">
    $(function () {
        //   $(":input").prop("disabled", true);
    });

    function rejectApplication() {
        $("#rejectModal").modal();

    }
    function requestEdit()
    {
        $("#requestEditModal").modal();
        $('#errorList').summernote(
            {
                height: 200

            }
        );

    }


    $('#requestEditModal').on('shown.bs.modal',
        function (e) {
            $("#errorList").focus();
            $('#errorList').trigger('focus');
       //     alert('done');


        });

    function checkForm() {
        if ($('#errorList').summernote('isEmpty')) {
            alert('error list cannot be empty');
            $('#errorList').summernote('focus')
            return false;
        }
        return true;
    }
    function confirmReview(ref) {
        $("#reviewAccModal").modal();
            @*bootbox.dialog(
                {
                    title: "Confirm Action",
                    message: "Mark as Successfully Reviewed?<br/>",
                    buttons: {
                        success: {
                            label: "OK",
                            className: "btn-success",
                            callback: function() {
                                document.location.href = "@Url.Action("ReviewSuccessfully", "Admin")?_ref=" +
                                    ref;
                            }
                        },
                        main: {
                            label: "Cancel",
                            className: "btn-danger",
                            callback: function() {

                            }
                        }

                    }
                });*@

    };


    function noStaffSignFound()
    {
        bootbox.alert("No staff signature found for your account. Please Upload one now");
        $("#uploadStaffSignatureModal").modal();
    }
</script>
