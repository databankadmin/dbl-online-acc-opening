                    <div id="photoIdVerificationDiv">

                    </div>
                </div>
            </div>


        </div>
    </div>
</div>


<div class="modal fade" id="requestEditModal">
    <form method="post" action="@Url.Action("SendEditRequest", "Admin")" enctype="multipart/form-data" onsubmit="javascript:return checkForm()">
        @Html.AntiForgeryToken()
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title">Request for Edit - List identified errors </h4>
                    <input type="hidden" name="itemId" id="itemId" value="@Model.Id" />
                </div>
                <div class="modal-body">
                    <textarea name="errorList" id="errorList" class="form-control" placeholder="error list here"></textarea>
                    <br />
                    <fieldset>
                        <legend>Indicate sections of errors</legend>
                        <ul>
                            <li>
                                <label style="font-weight:normal;">
                                    <input type="checkbox" name="dbl" id="dbl"> DBL Form
                                </label>
                            </li>
                            <li>
                                <label style="font-weight:normal;">
                                    <input type="checkbox" name="fileUpload" id="fileUpload"> File Uploads
                                </label>
                            </li>

                            <li>
                                <label style="font-weight:normal;">
                                    <input type="checkbox" name="aml" id="aml"> AML Form
                                </label>
                            </li>


                            <li>
                                <label style="font-weight:normal;">
                                    <input type="checkbox" name="eti" id="eti"> Electronic Indemnity
                                </label>
                            </li>
                        </ul>
                    </fieldset>
                </div>
                <div class="modal-footer">
                    <input type="submit" value="Send Now" class="btn btn-primary" />
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>

                </div>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->




    </form>

</div>








<div class="modal fade" id="manualCardValidationModal">

    <form method="post" action="@Url.Action("ManualCardValidation", "Admin")">
        @Html.AntiForgeryToken()

        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">How was the verification done?</h3>
                </div>
