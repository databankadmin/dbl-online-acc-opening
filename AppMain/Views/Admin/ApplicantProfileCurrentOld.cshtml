                    <div class="table-responsive">
                        <table class="table" style="width:60%;">
                            <tr>
                                <th class="theader">Thumbnail</th>
                                <th class="theader">Type</th>
                                <th class="theader">Download</th>
                            </tr>

                            <tr>
                                @{
                                    bool isPdf = Utilities.IsFilePdf(Model.CSDFormPath);
                                    string thumbnailPath = isPdf == true ? "pdf.png" : Model.CSDFormPath;
                                    string csddownloadFileName = "CSD_Form" + "_" + Model.CSDFormPath;
                                    <td>
                                        <a href="~/Images/@Model.CSDFormPath" target="_blank">
                                            <img src="~/Images/@thumbnailPath" style="width:50px; height:50px;" />
                                        </a>

                                    </td>
                                    <td>CSD Form</td>

                                    <td>
                                        <a href="~/Images/@Model.CSDFormPath" title="download file" download="@csddownloadFileName">
                                            <i class="fa fa-download fa-2x" style="color:#00a65a !important"></i>
                                        </a>
                                    </td>
                                }
                            </tr>

                            @{
                                foreach (var item in accountUploads)
                                {
                                    isPdf = Utilities.IsFilePdf(item.Path);
                                    thumbnailPath = isPdf == true ? "pdf.png" : item.Path;
                                    string downloadFileName = item.FileUploadTypeName.Replace(" ", "_") + "_" + item.Path;
                                    <tr>
                                        <td>
                                            <a href="~/Images/@item.Path" target="_blank">
                                                <img src="~/Images/@thumbnailPath" style="width:50px; height:50px;" />
                                            </a>

                                        </td>
                                        <td>@item.FileUploadTypeName</td>

                                        <td>
                                            <a href="~/Images/@item.Path" title="download file" download="@downloadFileName">
                                                <i class="fa fa-download fa-2x" style="color:#00a65a !important"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </table>
                    </div>
                </div>
                <div class="tab-pane" id="aml">
                    <div class="table-responsive">
                        <table class="table">
                            <tr>
                                <th>Question</th>
                                <th>Response</th>
                                <th>Remark</th>
                                <th>Rating</th>

                            </tr>
                            @{
                                foreach (var item in accountAmlResponses)
                                {
                                    <tr>
                                        <td>@item.QuestionText</td>
                                        <td>@item.YesNo</td>
                                        <td>@item.Remark</td>
                                        <td>@item.RatingValueTxt</td>
                                    </tr>
                                }
                                <tr>
                                    <td></td>
                                    <th colspan="2">TOTAL AML SCORE </th>
                                    <th style="border-bottom:double;">@accountAmlResponses.Where(x => x.RatingValue > 0).Sum(x => x.RatingValue).ToString("N2")</th>
                                </tr>

                                <tr>
                                    <td></td>
                                    <th colspan="2">AML RATING</th>
                                    <th style="border-bottom:double">
                                        @Utilities.GetAMLRating(accountAmlResponses.Where(x => x.RatingValue > 0).Sum(x => x.RatingValue))

                                    </th>
                                </tr>
                            }
                        </table>
                    </div>

                    <center>
                        <a class="btn btn-success btn-sm" style="color:white;" href="@Url.Action("AmlFormData", "Pdf", new { _refNumber = Model.Id.ToString().Encrypt() })">
                            <i class="fa fa-file"></i> Generate Pdf
                        </a>
                        @{
                            if (allowCSDFormGenerate)
                            {
                                <a class="btn btn-primary btn-sm" style="color:white;" href="@Url.Action("GetCSDPDf", "Pdf", new { _refNumber = Model.Id.ToString().Encrypt() })">
                                    <i class="fa fa-file"></i> Get CSD Pdf
                                </a>

                            }
                            else
                            {
                                <a class="btn btn-primary btn-sm" style="color:white;" href="#" onclick="javascript:noStaffSignFound()">
                                    <i class="fa fa-file"></i> Get CSD Pdf
                                </a>
                            }
                        }





                    </center>
                </div>


                <div class="tab-pane" id="eti">

                    <fieldset>
                        @{
                            if (accountETI == null)
                            {
                                accountETI = new AccountETIModel
                                {
                                    Text1 = "Text 1",
                                    Text2 = "Text 2",
                                    Text3 = "Text 3",
                                    Text4 = "Text 4"

                                };
                            }
                        }
                        <br />
                        <div class="fieldset-content" style="text-align:inherit;font-size:18px;">

                            I / We, <input readonly type="text" style="width:700px;display:inline; font-weight:bold; text-align:center; font-style:italic" value="@accountETI.Text1" />, the undersigned,<br /><br />
                            here acting in the capacity of <input readonly type="text" style="width:700px;display:inline; font-weight:bold; text-align:center; font-style:italic" value="@accountETI.Text2" /<br /> <br />,
                            authorise and instruct Databank Brokerage Limited to execute within the earliest possible time, the
                            instructions which I am / we are likely to transmit by fax, telephone and e-mail, with regard to securities
                            transactions generally, in the name of <input type="text" readonly style="width:700px;display:inline; font-weight:bold; text-align:center; font-style:italic" value="@accountETI.Text3" / unless
                            otherwise indicated, pending receipt or not
                            of my / our original written conrmation, which when issued by me / us will be annotated with “Instructions
                            already given by telephone / e-mail or fax.
                            <br />
                            <br />
                            I am / We are however perfectly aware of inherent risks there may be in transmission of instructions by fax,
                            telephone and e-mail, such as, but not limited to, delays and errors in transmission, incomprehension,
                            absence of condentiality, transmission by unauthorised persons and loss caused thereby, and agree to
                            bear the consequences thereof.
                            <br />
                            <br />
                            In consideration of your agreeing to carry out my / our instructions by such means as aforesaid, I / we, the
                            undersigned, here acting in the capacity of <input type="text" readonly style="width:700px;display:inline; font-weight:bold; text-align:center; font-style:italic" value="@accountETI.Text4" / ,
                            undertake:
                            <br /><br />
                            <ul style="list-style-type:disc">
                                <li>to hold you or any of your agents blameless in the execution of such instructions;</li>
                                <li>not to enter any action against you (and in so far as need be); and</li>
                                <li>
                                    to indemnify you for all losses and all actions, proceedings and demands that might be entered or made
                                    against you by any third party as a result of your complying with instructions transmitted by the above
                                    means, as well as for fees, costs and expenses which you might incur in relation to such actions,
                                    proceedings or demands.

                                </li>
                            </ul>

                            <br />
                            This authorisation is given by me / us to Databank Brokerage Limited and is valid until formal revocation by
                            written instructions from me / us.

                            <br /><br />
                            Dated this @DateTime.Now.Date.ToString("dd") day of @DateTime.Now.ToString("MMMM yyyy").
                            <br />
                            <br />

                            <table class="table">
                                <tr>
                                    <th>Name</th>
                                    <td>@accountETI.Name1</td>
                                    <th>Email</th>
                                    <td>@accountETI.Email1</td>
                                </tr>
                                @{
                                    if (Model.AccountTypeId == 4)
                                    {
                                        <tr>
                                            <th>Name</th>
                                            <td>@accountETI.Name2</td>
                                            <th>Email</th>
                                            <td>@accountETI.Email2</td>
                                        </tr>
                                    }
                                }

                            </table>




                        </div>



                    </fieldset>

                    <center>
                        <a class="btn btn-success btn-sm" style="color:white;" href="@Url.Action("ETIFormData", "Pdf", new { _refNumber = Model.Id.ToString().Encrypt() })">
                            <i class="fa fa-file"></i> Generate Pdf
                        </a>



                        <a class="btn btn-success btn-sm" style="color:white;" href="@Url.Action("GetCSDPDf", "Pdf", new { _refNumber = Model.Id.ToString().Encrypt() })">
                            <i class="fa fa-file"></i> Get CSD Pdf
                        </a>

                    </center>
                </div>


                @{
                    if (checkListItems != null)
                    {
                        <div class="tab-pane" id="chcklist">
                            @{
                                foreach (var item in checkListItems)
                                {
                                    <p>
                                        @context.CheckListItems.Find(item.CheckListItemId).Name
                                    </p>
                                }
                            }
                        </div>
                    }
                }



                @{
                    if (Model.StatusId == 1)
                    {
                        <hr />
                        <a href="javascript:confirmReview('@Model.Id')" class="btn btn-success">Approve</a>
                        <a href="#" style="color:white;" onclick="javascript:requestEdit()" class="btn btn-warning">Request Edit</a>

                        <a href="javascript:rejectApplication()" class="btn btn-danger">Reject or Cancel</a>
                    }
                }


            </div>
            </div>
    </div>
</div>






<div class="modal fade" id="rejectModal">
    <div class="modal-dialog">
        <div class="login-card card-block login-card-modal">
            <div class="card m-t-15">
                <div class="auth-box card-block">
                    <form method="post" action="@Url.Action("CancelOrRejectApplication", "Admin")">
                        @Html.AntiForgeryToken()
                        <div class="modal-content">
                            <div class="modal-header">
                                <h3 class="modal-title">Cancel or Reject Application</h3>
                            </div>
                            <div class="modal-body">
                                <div class="card-body">

                                    <input type="hidden" name="applicationId" id="applicationId" value="@Model.Id" />
                                    <select name="action" class="form-control" required>
                                        <option value="">-choose action-</option>
                                        <option value="C">Cancel</option>
                                        <option value="R">Reject</option>
                                    </select>
                                    <br />
                                    <textarea name="comments" id="comments" class="form-control" rows="4" required style="margin-bottom:12px;"></textarea>

                                    <label style="font-weight:normal;">
                                        <input type="checkbox" name="notifyApplicant" id="notifyApplicant">Notify Applicant
                                    </label>


                                </div>


                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-info">Save</button>
                                <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>
                            </div>
                        </div><!-- /.modal-content -->


                    </form>

                </div>
            </div>


        </div>
    </div>
</div>


<div class="modal fade" id="photoIdVerificationModal">
