@model IEnumerable<AppModels.AccountBasicModel>
@using AppMain.Providers

@{
    ViewBag.Title = "Applications";
    Layout = "~/Views/Shared/_Admin.cshtml";
    var context = new DBHelper.Schema.DBLAccountOpeningContext();
}

<link rel="stylesheet" href="~/AdminLTE/plugins/datatables-bs4/css/dataTables.bootstrap4.css">



<script src="~/Scripts/moment-with-locales.js"></script>


<link rel="stylesheet" type="text/css" href="~/files/bower_components/datatables.net-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" type="text/css" href="~/files/assets/pages/data-table/css/buttons.dataTables.min.css">
<link rel="stylesheet" type="text/css" href="~/files/bower_components/datatables.net-responsive-bs4/css/responsive.bootstrap4.min.css">


<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="https://code.jquery.com/jquery-1.12.4.js"></script>
<script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>

<div class="col-md-12">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                Applications
            </h3>
        </div>
        <div class="card-body">

            <form class="form-inline">

                <div class="form-group">

                    <select name="accountType" id="accountType" class="form-control" style="margin-right:2px;margin-bottom:2px;">
                        <option value="0">Account Type</option>
                        @{
                            foreach (var item in context.AccountTypes)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }

                    </select>
                </div>


                <div class="form-group">

                    <select name="investmentTypeId" id="investmentTypeId" class="form-control" style="margin-right:2px;margin-bottom:2px;">
                        <option value="0">Investment Type</option>
                        @{
                            foreach (var item in context.InvestmentTypes)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }

                    </select>
                </div>
                <div class="form-group">

                    <select name="statusId" id="statusId" class="form-control" style="margin-right:2px;margin-bottom:2px;">
                        <option value="0">Status</option>
                        @{
                            foreach (var item in context.ApplicationStatus)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }

                    </select>


                </div>

                <div class="form-group">

                    <label for="from">From</label>
                    <input type="text" id="from" class="form-control" name="from" style="width: 120px; height: 38px;">

                </div>

                <div class="form-group">
                    <label for="to">To</label>
                    <input type="text" id="to" class="form-control" name="to" style="width: 120px; height: 38px;">
                </div>

                <input type="text" id="key" class="form-control" name="key" placeholder="search key..." style="height: 38px; margin-right: 5px; margin-bottom:2px;">


                <button type="submit" class="btn btn-success" style="margin-left:2px;">Appy Filters</button>
            </form>
            <br />



            <div class="row">
                <div class="table-responsive">
                    <table class="table table-condensed table-striped">
                        <thead>
                            <tr>
                                <th>Ref. No</th>
                                <th>Name</th>
                                <th>Account Type</th>
                                <th>Investment Type</th>
                                <th>Status</th>
                                <th>Back Connect Accn.</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                foreach (var item in Model.OrderByDescending(x => x.CreatedDate))
                                {
                            <tr>
                                <td><a style="color: #0000ff" href="@Url.Action("ApplicantProfile", new { _refNumber = item.Id.ToString().Encrypt() })">@item.RefNo</a></td>
                                <td>@item.AccountName</td>

                                <td>@item.AccountTypeName</td>

                                <td>@item.InvestmentTypeName</td>
                                <td>@item.StatusName</td>
                                <td>@item.BackConnectAccountNumber</td>
                                <td data-sort="@item.CreatedDate.ToString("O")">@item.CreatedDate.ToString()</td>

                            </tr>
                                }

                            }
                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/AdminLTE/plugins/datatables/jquery.dataTables.js"></script>
<script src="~/AdminLTE/plugins/datatables-bs4/js/dataTables.bootstrap4.js"></script>


<script src="~/files/bower_components/datatables.net/js/jquery.dataTables.min.js" type="text/javascript"></script>
<script src="~/files/bower_components/datatables.net-buttons/js/dataTables.buttons.min.js" type="text/javascript"></script>
<script src="~/files/assets/pages/data-table/js/jszip.min.js" type="text/javascript"></script>
<script src="~/files/assets/pages/data-table/js/pdfmake.min.js" type="text/javascript"></script>
<script src="~/files/assets/pages/data-table/js/vfs_fonts.js" type="text/javascript"></script>
<script src="~/files/bower_components/datatables.net-buttons/js/buttons.print.min.js" type="text/javascript"></script>
<script src="~/files/bower_components/datatables.net-buttons/js/buttons.html5.min.js" type="text/javascript"></script>
<script src="~/files/bower_components/datatables.net-bs4/js/dataTables.bootstrap4.min.js" type="text/javascript"></script>
<script src="~/files/bower_components/datatables.net-responsive/js/dataTables.responsive.min.js" type="text/javascript"></script>




<script>
    $(function () {
        $('table').DataTable({
            "paging": true,
            "lengthChange": false,
            "searching": true,
            "ordering": true,
            "info": true,
            "autoWidth": false,
            "aaSorting": [[6, "desc"]],
            dom: 'Bfrtlp',
            buttons: [
                {
                    extend: 'excel',

                }

            ]

        });
    });
</script>




<script>
    $(function () {
        var dateFormat = "mm/dd/yy",
            from = $("#from")
                .datepicker({
                    defaultDate: "+1w",
                    changeMonth: true,
                    numberOfMonths: 1
                })
                .on("change", function () {
                    to.datepicker("option", "minDate", getDate(this));
                }),
            to = $("#to").datepicker({
                defaultDate: "+1w",
                changeMonth: true,
                numberOfMonths: 1
            })
                .on("change", function () {
                    from.datepicker("option", "maxDate", getDate(this));
                });

        function getDate(element) {
            var date;
            try {
                date = $.datepicker.parseDate(dateFormat, element.value);
            } catch (error) {
                date = null;
            }

            return date;
        }
    });
</script>




<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />


<script type="text/javascript">
    $(document).ready(function () {
        @{
    if (!string.IsNullOrEmpty(ViewBag.accountType.ToString()))
    {
        if (ViewBag.accountType != 0)
        {
            <text>
                $("#accountType").val('@int.Parse(ViewBag.accountType.ToString())');
            </text>

        }
    }
    if (!string.IsNullOrEmpty(ViewBag.investmentTypeId.ToString()))
    {
        if (ViewBag.investmentTypeId != 0)
        {
            <text>
                $("#investmentTypeId").val('@int.Parse(ViewBag.investmentTypeId.ToString())');
            </text>

        }
    }
    if (ViewBag.statusId != 0 && !string.IsNullOrEmpty(ViewBag.statusId.ToString()))
    {
        <text>
            $("#statusId").val('@int.Parse(ViewBag.statusId.ToString())');
        </text>

    }
    if (!string.IsNullOrEmpty(ViewBag.from) && !string.IsNullOrEmpty(ViewBag.from.ToString()))
    {
        <text>
            $("#from").val('@ViewBag.from.ToString()');
        </text>

    }

    if (!string.IsNullOrEmpty(ViewBag.to.ToString()))
    {
        <text>
            $("#to").val('@ViewBag.to.ToString()');
        </text>

    }

    if (ViewBag.key != null)
    {
        <text>
            $("#key").val('@ViewBag.key.ToString()');
        </text>

    }

}

    });
    </script>
