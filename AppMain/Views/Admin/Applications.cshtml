@model IEnumerable<AppModels.AccountBasicModel>
@using AppMain.Providers

@{
    ViewBag.Title = "Applications";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<link rel="stylesheet" href="~/AdminLTE/plugins/datatables-bs4/css/dataTables.bootstrap4.css">


<div class="col-md-12">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                Applications
           </h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="table-responsive">
                    <table class="table table-condensed table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Account Type</th>
                                <th>Investment Type</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                foreach (var item in Model.OrderByDescending(x => x.CreatedDate))
                                {
                                    <tr>
                                        <td><a style="color: #0000ff" href="@Url.Action("ApplicantProfile", new {_refNumber=item.Id.ToString().Encrypt()})">@item.AccountName</a></td>
                                        <td>@item.AccountTypeName</td>
                                        <td>@item.InvestmentTypeName</td>
                                        <td>@item.StatusName</td>
                                        <td data-sort="@item.CreatedDate.ToString("O")">@item.CreatedDate.ToString()</td>

                                    </tr>
                                }

                            }
                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/AdminLTE/plugins/datatables/jquery.dataTables.js"></script>
<script src="~/AdminLTE/plugins/datatables-bs4/js/dataTables.bootstrap4.js"></script>


<script>
    $(function () {
        $('table').DataTable({
            "paging": true,
            "lengthChange": false,
            "searching": true,
            "ordering": true,
            "info": true,
            "autoWidth": false,
            "aaSorting": [[4, "desc"]]
        });
    });
</script>


