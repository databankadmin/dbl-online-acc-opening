        <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
        <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />



        <script type="text/javascript">
    $(document).ready(function () {
        var ctx = document.getElementById("chart002");
    var myChart = new Chart(ctx,
        {
            type: 'bar',
            data: {
                labels: [
                    @{
                            foreach (var item in investmentTypesData)
                            {
                               <text>
                                   '@item.Label.Trim()',
                               </text>
                            }
                       }
                ],

                datasets: [
                    {
                        label: 'count',
                        fill: false,

                        data: [
                            @{
                                    foreach (var item in investmentTypesData)
                            {
                               <text>
                                   @item.IntVal,
                               </text>
                            }
                              }
                        ],

                         backgroundColor: [
                                @{

                                    foreach (var item in statusTypesData)
                                    {
                                        <text>
                                            "@item.Color",
                                        </text>
                                    }
                                }

                            ],
 borderColor: [
                                @{

                                    foreach (var item in statusTypesData)
                                    {
                                        <text>
                                            "@item.Color",
                                        </text>
                                    }
                                }

                            ],                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,

                legend: {
                    display: false,
                    labels: {
                        fontColor: "black",
                        boxWidth: 20,
                        padding: 20
                    }
               },


                scales: {
                    xAxes: [
                        {
                            ticks: {
                                maxRotation: 90,
                                minRotation: 80
                            }
                        }
                    ],
                    yAxes: [
                        {
                            ticks: {
                                beginAtZero: true
                            }
                        }
                    ]
                }
            }
            });






        new Chart(document.getElementById("chart003"),
            {
                type: 'doughnut',
                data: {
                    labels: [
                        @{

                            foreach (var item in statusTypesData)
                            {
                                <text>
                                    "@item.Label",
                                </text>
                            }
                        }
                    ],

                    datasets: [
                        {
                            label: "count: ",

                            backgroundColor: [
                                @{

                                    foreach (var item in statusTypesData)
                                    {
                                        <text>
                                            "@item.Color",
                                        </text>
                                    }
                                }

                            ],


                            data:
                            [
                                @{

                                    foreach (var item in statusTypesData)
                                    {
                                        <text>
                                    "@item.IntVal",
                                        </text>
                                    }
                                }


                            ]


                        }
                    ]
                },

                options: {
                    responsive: true,
                    legend: {
                        position: 'right',
                        labels: {
                            fontColor: "black",
                            boxWidth: 20,
                            padding: 20
                        }
                    }
                },

            })
    });




    $(function () {
        $('table').DataTable({
            "paging": true,
            "lengthChange": false,
            "searching": true,
            "ordering": true,
            "info": true,
            "autoWidth": false,
            "aaSorting": [[2, "desc"]],
          //  dom: 'Bfrtlp',

        });
    });




        </script>



