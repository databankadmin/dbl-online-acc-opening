<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4>
                    Investment Types
                </h4>
            </div>
            <div class="card-block">
                <div class="chartJS">
                    <canvas id="chart002" height="262" width="495" style="width: 495px; height: 262px;"></canvas>
                </div>

            </div>
        </div>
    </div>
    <div class="col-md-6">



        <div class="card">
            <div class="card-header">
                <h4>Account Status </h4>
            </div>
            <div class="card-block">
                <div class="chartJS">
                    <canvas id="chart003" height="262" width="495" style="width: 495px; height: 262px;"></canvas>
                </div>

            </div>
        </div>


    </div>
</div>

<br/>

<div class="row">


    <div class="col-md-12">
        <div class="card" style="padding:1%">
            <br />
            <h3 class="card-title">
                Recent User Activities
            </h3>
                <table class="table table-condensed table-striped">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Activity</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            foreach (var item in context.AuditLogs.OrderByDescending(x => x.CreatedDate).Take(10))
                            {
                                <tr>
                                    <td>@item.UserId</td>
                                    <td>@item.Activity</td>
                                    <td data-sort="@item.CreatedDate.ToString("O")">@item.CreatedDate.ToString()</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
        </div>


    </div>
</div>


