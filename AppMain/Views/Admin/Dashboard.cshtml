@using AppModels
@using DBHelper
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Admin.cshtml";

    var investmentTypesData = ViewBag.investmentTypesData as List<NameValueModel>;
    var statusTypesData = ViewBag.statusTypesData as List<NameValueModel>;
    var context = new DBHelper.Schema.DBLAccountOpeningContext();

}


