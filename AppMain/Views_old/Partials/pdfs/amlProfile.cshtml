        <div class="row" style="padding-left:2%; padding-right:2%;">
            <img src="@logo1" style="width:300px; height:80px; display:inline;" />
            <img src="@logo2" style="width:300px; height:80px; float:right;" />
        </div>
    </div>*@

    
