@model AppModels.AccountBasicModel
@using AppUtils
@using AppModels
@using AppMain.Providers
@{
    Layout = "~/Views/Shared/_pdfLayout.cshtml";
    ViewBag.Title = "Applicant AML Profile | " + Model.AccountName;
    Guid applicationId = Guid.Parse(ViewBag.applicationId.ToString());
    var accountAmlResponses = Utilities.GetAccountAMlReponses(applicationId);
    var context = new DBHelper.Schema.DBLAccountOpeningContext();
    string baseUrl = Utilities.GetBaseUrl();
    string logo1 = baseUrl + "/Images/pdf_header_logo.png";
    string logo2 = baseUrl + "/Images/pdf_header_databank.png";

}


<style type="text/css">

    th.theader {
        color: #fff;
        background-color: #00a65a !important;
        font-size: 16px;
        /*padding-top: 4px;
        padding-bottom: 4px;*/
    }
</style>


<style type="text/css" media="all">
    #mytable td {
        padding: 0.1px;
    }

    #hdr1, #hdr2, #hdr3, #hdr4, #hdr5, #hdr6 {
        background-color: #00a65a !important;
        color: white;
        padding-top: 2px;
        padding-bottom: 2px;
        padding-left: 5px;
        border-radius: 2px;
    }

    td {
        padding: 1px !important;
        margin: 1px !important;
    }

    tr, dl, dd {
        padding: 1px !important;
        margin: 1px !important;
    }
</style>

<div class="card" style="border:1px solid; margin:1px !important;padding:1px !important;">
    <div class="row">
        <div class="row" style="padding-left:4%; padding-right:4%;">
            <img src="~/Images/pdf_header_logo.png" style="width:300px; height:80px; display:inline;" />
            <img src="~/Images/pdf_header_databank.png" style="width:300px; height:80px; float:right;" />
        </div>

    </div>

    <div class="col-md-11">
        <div class="card">
            <table class="table table-borderless table-condensed" cellpadding="0" cellspacing="0" style="padding:0;">
                <tr>
                    <th>Question</th>
                    <th>Response</th>
                    <th>Remark</th>
                    <th>Rating</th>

                </tr>
                @{
                    foreach (var item in accountAmlResponses)
                    {
                        <tr>
                            <td>@item.QuestionText</td>
                            <td>@item.YesNo</td>
                            <td>@item.Remark</td>
                            <td>@item.RatingValueTxt</td>
                        </tr>
                    }
                    <tr>
                        <td></td>
                        <th colspan="2">TOTAL AML SCORE </th>
                        <th style="border-bottom:double;">@accountAmlResponses.Where(x => x.RatingValue > 0).Sum(x => x.RatingValue).ToString("N2")</th>
                    </tr>

                    <tr>
                        <td></td>
                        <th colspan="2">AML RATING</th>
                        <th style="border-bottom:double">
                            @Utilities.GetAMLRating(accountAmlResponses.Where(x => x.RatingValue > 0).Sum(x => x.RatingValue))

                        </th>
                    </tr>
                }
            </table>
        </div>
        </div>
    </div>





