                return STPadServerLibApi.Sensor.setSignRect(new STPadServerLibApi.Sensor.Params.setSignRect(0, top, sigcanvas.width, sigcanvas.height));
            }, STPadServerLibCommons.defaultReject)
            .then(function (value) {
                var left;
