                        width = 265;
                        height = 18;
                        break;
                    case padTypes.omegaUSB:
                    case padTypes.omegaSerial:
                        left = 40;
                        top = 350;
                        width = 520;
                        height = 40;
                        break;
                    case padTypes.gammaUSB:
                    case padTypes.gammaSerial:
                        left = 40;
                        top = 350;
                        width = 670;
                        height = 40;
                        break;
                    case padTypes.deltaUSB:
                    case padTypes.deltaSerial:
                    case padTypes.deltaIP:
                        left = 40;
