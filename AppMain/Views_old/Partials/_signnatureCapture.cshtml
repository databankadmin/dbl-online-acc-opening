                buttonLeft = buttonLeft + buttonDiff;
                return STPadServerLibApi.Sensor.addHotSpot(new STPadServerLibApi.Sensor.Params.addHotSpot(Math.round(buttonLeft), buttonTop, buttonSize, buttonSize));
