 <div class="form-row">
            <div class="form-flex">

    </div>
    </div>
-->


<script type="text/javascript">
    function accountActivityChanged(val, ctrl) {
        if (parseInt(val) === 5) {
            $("#" + ctrl).slideDown();
            $("#" + ctrl).focus();
        }
        else {
            $("#" + ctrl).slideUp();
            $("#" + ctrl).val("");
        }
    }

</script>
