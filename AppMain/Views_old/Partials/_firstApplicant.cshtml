            </div>

            <div class="form-group">
                <label for="residentPermitIssueDate" style="font-weight:700;font-style:italic">Permit Issue Date</label>
                <input type="text" style="background-color:#f5f5f5" class="form-control" name="residentPermitIssueDate" id="residentPermitIssueDate" readonly>
            </div>

            <div class="form-group">
                <label for="residentPermitExpiryDate" style="font-weight:700;font-style:italic">Permit Expiry Date</label>
