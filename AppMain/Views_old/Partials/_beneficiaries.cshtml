@{
    var context = new DBHelper.Schema.DBLAccountOpeningContext();
}


<link rel="stylesheet" href="//code.jquery.com/ui/1.13.1/themes/base/jquery-ui.css">
@*<script src="https://code.jquery.com/ui/1.13.1/jquery-ui.js"></script>*@

<h4 class="myHeader">Beneficiaries</h4>


<div id="tabs">
    <ul>
        <li><a href="#tabs-1">Beneficiary 1 *</a></li>
        <li><a href="#tabs-2">Beneficiary 2</a></li>
        <li><a href="#tabs-3">Beneficiary 3</a></li>
        @*<li><a href="#tabs-4">Beneficiary 4</a></li>
        <li><a href="#tabs-5">Beneficiary 5</a></li>*@

    </ul>
    <div id="tabs-1">

        <div class="form-row">
            <div class="form-flex">

                <div class="form-group">
            <label for="beneficiary1TitleId">Title *</label>
            <select name="beneficiary1TitleId" id="beneficiary1TitleId" required onchange="javascript: titleChanged(this.value,'beneficiary1TitleOther')" style="width:200px;">
                <option value="">-Title-</option>
                @{
                    foreach (var item in context.Titles)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                }
            </select>
            <input type="text" name="beneficiary1TitleOther" id="beneficiary1TitleOther" class="form-control" style="margin-top:3px; display:none;" placeholder="other(please specify)" />
        </div>

                <div class="form-group">
                    <label for="beneficiary1Surname">Surname *</label>
                    <input type="text" class="form-control" name="beneficiary1Surname" id="beneficiary1Surname" required>
                </div>

                <div class="form-group">
                    <label for="beneficiary1Fname">First and other name(s) *</label>
                    <input type="text" class="form-control" name="beneficiary1Fname" id="beneficiary1Fname" required>
                </div>

                <div class="form-group">
                    <label for="beneficiary1Relation">Relationship with applicant *</label>
                    <input type="text" class="form-control" name="beneficiary1Relation" id="beneficiary1Relation" required>
                </div>

            </div>
        </div>



        <div class="form-row">
            <div class="form-flex">
                <div class="form-group">
                    <label for="beneficiary1GenderId">Gender *</label>
                    <select class="form-control" name="beneficiary1GenderId" id="beneficiary1GenderId" required style="width:200px;">
                        <option value="">-select-</option>
                        @{
                            foreach (var item in context.Genders)
                            {

                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="beneficiary1MaritalStatusId">Marital Status </label>

                    <select class="form-control" name="beneficiary1MaritalStatusId" id="beneficiary1MaritalStatusId" style="width:200px;">
                        <option value="">-select-</option>
                        @{
                            foreach (var item in context.MaritalStatus.Where(x => x.IsActive))
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="beneficiary1BirthDate">Date of birth</label>
                    <input type="date" class="form-control" name="beneficiary1BirthDate" id="beneficiary1BirthDate" style="background-color: rgb(245, 245, 245); border-color: green;">
                </div>
                <div class="form-group">
                    <label for="beneficiary1placeOfBirth">Place of Birth</label>
                    <input type="text" class="form-control" name="beneficiary1placeOfBirth" id="beneficiary1placeOfBirth">
                </div>
            </div>
        </div>



        <div class="form-row">
            <div class="form-flex">
                <div class="form-group">
                    <label for="beneficiary1NationalityId">Country of Origin *</label>
                    <select class="form-control" name="beneficiary1NationalityId" id="beneficiary1NationalityId" required style="width:200px;">
                        <option value="">-Select-</option>
                        @{
                            foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                            {
                                if (item.ID == 81)
                                {
                                    <option value="@item.ID" selected>@item.CountryName</option>
                                    continue;
                                }
                                <option value="@item.ID">@item.CountryName</option>
                            }
                        }
                    </select>

                </div>

                <div class="form-group">
                    <label for="beneficiary1countryOfResidenceId">Country of Residence *</label>
                    <select class="form-control" name="beneficiary1countryOfResidenceId" id="beneficiary1countryOfResidenceId" required style="width:200px;">
                        <option value="">-Select-</option>
                        @{
                            foreach (var item in context.Countries.OrderBy(x => x.CountryName))
                            {
                                if (item.ID == 81)
                                {
                                    <option value="@item.ID" selected>@item.CountryName</option>
                                    continue;
                                }
                                <option value="@item.ID">@item.CountryName</option>
                            }
                        }
                    </select>

                </div>

                <div class="form-group">
                    <label for="beneficiary1photoIdType">Photo ID Type</label>
                    <select class="form-control" name="beneficiary1photoIdType" id="beneficiary1photoIdType">
                        <option value="">-Select-</option>
                        @{
                            foreach (var item in context.IDCardTypes)
                            {

                                <option value="@item.Id">@item.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="beneficiary1IDNumber">ID Number</label>
                    <input type="text" class="form-control" name="beneficiary1IDNumber" id="beneficiary1IDNumber">
                </div>
            </div>
        </div>



        <div class="form-row">
            <div class="form-flex">
                <div class="form-group">
                    <label for="beneficiary1IDPlaceOfIssue">Place of Issue</label>
                    <input type="text" class="form-control" name="beneficiary1IDPlaceOfIssue" id="beneficiary1IDPlaceOfIssue">
                </div>

                <div class="form-group">
                    <label for="beneficiary1IDIssueDate">ID Issue Date</label>
                    <input type="date" style="background-color:#f5f5f5" class="form-control" name="beneficiary1IDIssueDate" id="beneficiary1IDIssueDate">
                </div>

                <div class="form-group">
                    <label for="beneficiary1ExpiryDate">ID Expiry Date</label>
                    <input type="date" style="background-color:#f5f5f5" class="form-control" name="beneficiary1ExpiryDate" id="beneficiary1ExpiryDate" >
                </div>

                <div class="form-group">
                    <label for="beneficiaryPcnt1">Percentage Allocation *</label>
                    <input type="number" name="beneficiaryPcnt1" id="beneficiaryPcnt1" class="form-control" min="1" max="100" step="0.01" required placeholder="0.00" />
                </div>
            </div>
        </div>
    </div>



