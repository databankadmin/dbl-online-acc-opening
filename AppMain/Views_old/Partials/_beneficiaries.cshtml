<script type="text/javascript">
    function getTotalBeneficiary() {
        var total = parseFloat("0.00");

        if ($("#beneficiaryPcnt1").val() != '') {
            total = total + parseFloat($("#beneficiaryPcnt1").val());
        }

        if ($("#beneficiaryPcnt2").val() != '') {
            total = total + parseFloat($("#beneficiaryPcnt2").val());
        }

        if ($("#beneficiaryPcnt3").val() != '') {
            total = total + parseFloat($("#beneficiaryPcnt3").val());
        }

        if ($("#beneficiaryPcnt4").val() != '') {
            total = total + parseFloat($("#beneficiaryPcnt4").val());
        }

        if ($("#beneficiaryPcnt5").val() != '') {
            total = total + parseFloat($("#beneficiaryPcnt5").val());
        }
        return total;
    }

</script>
