    <script type="text/javascript">
        captureTarget = "";
        captureTargetHiddenField = "";
        hasAnsweredModal = false;

        function setZoom() {
            document.body.style.zoom = "95%";
        }




        $(document).ready(function () {
            setZoom();
            var firstApplicantIdTypeArr = getDropDownItems('firstApplicantIdType');
            var jointApplicantIdTypeArr = getDropDownItems('jointApplicantIdType');
            var itfApplicantIdTypeArr = getDropDownItems('itfApplicantIdType');
            var authorisedPersonApplicantIdTypeArr = getDropDownItems('authorisedPersonApplicantIdType');
            var intAuthorisedOfficer1IDTypeArr = getDropDownItems('intAuthorisedOfficer1IDType');
            var intAuthorisedOfficer2IDTypeArr = getDropDownItems('intAuthorisedOfficer2IDType');


            $("#firstApplicantNationality").change(function () {
                val = $("#firstApplicantNationality").val();
                if (Number(val) != 81) {
                    resetIDDropDownToPassportOnly('firstApplicantIdType')
                }
                else {
                    setDropDownValues('firstApplicantIdType', firstApplicantIdTypeArr)
                }
            });



            $("#jointApplicantNationality").change(function () {
                val = $("#jointApplicantNationality").val();
                if (Number(val) != 81) {
                    resetIDDropDownToPassportOnly('jointApplicantIdType')
                }
                else {
                    setDropDownValues('jointApplicantIdType', jointApplicantIdTypeArr)
                }
            });


            $("#itfApplicantNationality").change(function () {
                val = $("#itfApplicantNationality").val();
                if (Number(val) != 81) {
                    resetIDDropDownToPassportOnly('itfApplicantIdType')
                }
                else {
                    setDropDownValues('itfApplicantIdType', itfApplicantIdTypeArr)
                }
            });


            $("#authorisedPersonZipCountryId").change(function () {
                val = $("#authorisedPersonZipCountryId").val();
                if (Number(val) != 81) {
                    resetIDDropDownToPassportOnly('authorisedPersonApplicantIdType')
                }
                else {
                    setDropDownValues('authorisedPersonApplicantIdType', authorisedPersonApplicantIdTypeArr)
                }
            });

            $("#intAuthorisedOfficer1CountryId").change(function () {
                val = $("#intAuthorisedOfficer1CountryId").val();
                if (Number(val) != 81) {
                    resetIDDropDownToPassportOnly('intAuthorisedOfficer1IDType')
                }
                else {
                    setDropDownValues('intAuthorisedOfficer1IDType', intAuthorisedOfficer1IDTypeArr)
                }
            });

            $("#intAuthorisedOfficer2CountryId").change(function () {
                val = $("#intAuthorisedOfficer2CountryId").val();
                if (Number(val) != 81) {
                    resetIDDropDownToPassportOnly('intAuthorisedOfficer2IDType')
                }
                else {
                    setDropDownValues('intAuthorisedOfficer2IDType', intAuthorisedOfficer2IDTypeArr)
                }
            });

        });


        function resetIDDropDownToPassportOnly(ctrlId) {
            $('#' + ctrlId + ' option').remove();
            $('#' + ctrlId).append('<option value="">-select-</option>');
            $('#' + ctrlId).append('<option value="' + 4 + '">' + 'Passport' + '</option>');
        }

        function getDropDownItems(ctrlId) {
            var oldValuesArray = new Array();
            $('#' + ctrlId + ' option').each(function () {
                if ($(this).val() != "") {
                    var textId = $(this).text() + "_" + $(this).val()
                    oldValuesArray.push(textId);
                }
            });
            return oldValuesArray;
        }

        function setDropDownValues(ctrlId, valuesArr) {
            $('#' + ctrlId + ' option').remove();
            $('#' + ctrlId).append('<option value="">-select-</option>');
            valuesArr.forEach(function (item) {
                var result = item.split("_");
                $('#' + ctrlId).append('<option value="' + result[1] + '">' + result[0] + '</option>');
            });
        }


        function DateChanged(dob, ctrl) {
            //jointApplicantDOB
            minAge = 18;
            age = computeAge(new Date(dob));
            if (Number(age) < 0) {
                age = 0;
            }
            if (ctrl === "firstApplicantDOB" || "jointApplicantDOB") {
                if (age < minAge) {
                    swal("Applicant MUST NOT be less than " + minAge + " years.\nAge is: " + age);
                    $("#" + ctrl).val("");
                }
            }

        }





        function computeAge(birth) {
            var today = new Date();
            var nowyear = today.getFullYear();
            var nowmonth = today.getMonth();
            var nowday = today.getDate();

            var birthyear = birth.getFullYear();
            var birthmonth = birth.getMonth();
            var birthday = birth.getDate();

            var age = nowyear - birthyear;
            var age_month = nowmonth - birthmonth;
            var age_day = nowday - birthday;

            if (age_month < 0 || (age_month === 0 && age_day < 0)) {
                age = parseInt(age) - 1;
            }
            return parseInt(age);


        }

        function showMainForm() {
            $("#dialog").dialog("close");
            $("#signup-form :input").removeAttr("disabled");

        }
        function showCaptureModal(targetImg, targetHiddenFld) {
            $("#signDialog").css('display', 'block');

            captureTarget = targetImg;
            captureTargetHiddenField = targetHiddenFld;
            $("#signDialog").dialog({
                width: 1000,
                height: 700,
                autoOpen: false,
                modal: true,
                show: {
                    effect: "blind",
                    duration: 300
                },
                hide: {
                    effect: "explode",
                    duration: 1000
                }
            });

            $("#signDialog").dialog("open");

        }




        function clientTypeChanged(value) {
            if (value === "New") {
                // $("#existingClientTypeModalDiv").slideUp();
                hasAnsweredModal = true;
                showMainForm();
                $("#newClientTypeModalDiv").slideDown();
            }

            else if (value === "Existing") {
                $("#newClientTypeModalDiv").slideUp();
                $("#existingClientTypeModalDiv").slideDown();
            }
        }




        function existingClientOptionsHandler(index) {
            var number = Number(index);
            hasAnsweredModal = true;
            if (number === 1) {
                showMainForm();
            }
            else if (number === 2) {
                showMainForm();
            }

        }

        $("#dialog").dialog({
            beforeClose: function (event, ui) {
                if (hasAnsweredModal) {
                    return true;
                }
                else {
                    return false;

                }
            }
        });
    </script>

    @{
        if (user == null)
        {
            <script type="text/javascript">
                $("#signup-form :input").prop("disabled", true);
                $("#dialog").dialog({
                    width: 800,
                    height: 600,
                    autoOpen: false,
                    show: {
                        effect: "blind",
                        duration: 300
                    },
                    hide: {
                        effect: "explode",
                        duration: 1000
                    }
                });

                $("#dialog").dialog("open");
                $("#signDialog").css('display', 'none');

            </script>
        }
        else
        {
            <script>
                hasAnsweredModal = true;
                $("#dialog").dialog("close");
                $("#signup-form :input").removeAttr("disabled");

            </script>
        }
    }



    <style type="text/css">
        #firstApplicantOccupation, #instructionsEmploymentDetailsCurrentOccupation, #instructionsEmploymentDetailsPreviousOccupation, #jointApplicantOccupation,
        #authorisedPersonRelation, #nextOfKin1Relation, #nextOfKin2Relation {
            width: 100%;
        }
    </style>


    <script type="text/javascript">
        function countryOfOriginChanged(selectVal, ctrlDiv, txtFocus) {
            if (parseInt(selectVal) != 81) {
                $("#" + ctrlDiv).slideDown();
                $("#" + txtFocus).focus();
            }
            else {
                $("#" + ctrlDiv).slideUp();
            }
        }
        function titleChanged(val, ctrl) {
            if (parseInt(val) === 7) {
                $("#" + ctrl).slideDown();
                $("#" + ctrl).focus();
            }
            else {
                $("#" + ctrl).slideUp();
                $("#" + ctrl).val("");
            }
        }
    </script>

</body>


