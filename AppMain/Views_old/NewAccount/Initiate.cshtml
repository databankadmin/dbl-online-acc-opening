<body onload="onMainWindowLoad();" onbeforeunload="onMainWindowBeforeUnload();">
    @*@Html.Partial("~/Views/Partials/_header.cshtml")*@
    <div class="main" style="padding:0;">

        <div class="container">
            <img src="~/Images/brokerage_header.jpg" />
            @{
