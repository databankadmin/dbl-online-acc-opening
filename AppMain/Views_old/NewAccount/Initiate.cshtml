    </div>

    <div id="dialog" title="Let's get started with some basic questions!">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body" style="text-align:justify">
                    <div class="card-body" style="overflow:auto">
                        <div id="clientTypeModalDiv">
                            <p>
                                <label class="question">What type of client are you?</label>
                                <select name="" class="form-control" style="width:200px;" onchange="javascript:clientTypeChanged(this.value)">
                                    <option value="">-select-</option>
                                    <option value="New">New Client</option>
                                    <option value="Existing">Existing Client</option>
                                </select>
                            </p>
                        </div>

                        <div id="newClientTypeModalDiv" style="display:none;">
                            <form id="newClientForm">
                                <label class="question">Which of the following best describes you?</label><br />
                                <label>
                                    <input type="radio" name="group1" value="1" style="width:15px; height:15px;display:inline;" /> I have never previously opened a Databank account

                                </label>

                                <br />

                                <label>
                                    <input type="radio" name="group1" value="2" style="width:15px; height:15px;display:inline;" /> I want to make general enquiries
                                </label>

                            </form>
                        </div>


                        <div id="existingClientTypeModalDiv" style="display:none;">

                            <div class="panel-group" id="accordion" role="tablist" aria-multiselectable="true">
                                <div class="panel panel-default" style="border-radius:2px; border:2px thin #333;border-style:groove; padding:1%">
                                    <div class="panel-heading" role="tab" id="headingTwo">
                                        <h4 class="panel-title">
                                            <a class="collapsed" role="button" data-toggle="collapse" data-parent="#accordion" href="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo" style="color:#1f2222; font-size:16px; font-weight:bold;">
                                                I would like to have a different investment package (Equities or Fixed income)
                                            </a>
                                        </h4>
                                    </div>
                                    <div id="collapseTwo" class="panel-collapse collapse" role="tabpanel" aria-labelledby="headingTwo">
                                        <div class="panel-body" style="font-style:italic;">

                                            Please note that this is for account holders who wish to invest in a different investment vehicle (Equities or Fixed income),  You will be required complete an account opening form.<br />

                                            @*<a href="https://onlineservice.databankgroup.com/portal/" target="_blank"><i class="fa fa-hand-o-right"></i> Proceed to deposit</a><br />*@
                                            <a href="#" onclick="javascript:existingClientOptionsHandler('1')"><i class="fa fa-hand-o-right"></i> Yes, continue</a>
                                        </div>
                                    </div>
                                </div>
                                <br />
                                <div class="panel panel-default" style="border-radius:2px; border:2px thin #333;border-style:groove; padding:1%">
                                    <div class="panel-heading" role="tab" id="headingThree">
                                        <h4 class="panel-title">
                                            <a class="collapsed" role="button" data-toggle="collapse" data-parent="#accordion" href="#collapseThree" aria-expanded="false" aria-controls="collapseThree" style="color:#1f2222; font-size:16px; font-weight:bold;">
                                                I’ve forgotten my account details
                                            </a>
                                        </h4>
                                    </div>
                                    <div id="collapseThree" class="panel-collapse collapse" role="tabpanel" aria-labelledby="headingThree">
                                        <div class="panel-body" style="font-style:italic">
                                            <h3>Please provide the following details about your account</h3>
                                            <form method="post" action="@Url.Action("ForgottenAccount")" enctype="multipart/form-data">
                                                @Html.AntiForgeryToken()
                                                <table>
                                                    <tr>
                                                        <td><input type="text" placeholder="Name(*)" name="name" required class="form-control" style="width:320px;" /></td>
                                                        <td><input type="text" placeholder="Postal Address" name="address" class="form-control" style="width:320px;" /></td>
                                                    </tr>
                                                    <tr>
                                                        <td><input type="email" placeholder="Email(*)" class="form-control" required name="email" style="width:320px;" /></td>
                                                        <td><input type="text" placeholder="Telephone Number(*)" name="phone" required class="form-control" style="width:320px;" /></td>
                                                    </tr>

                                                    <tr>
                                                        <th colspan="2" style="align-content:center; text-align:center;">
                                                        </th>
                                                    </tr>
                                                </table>

                                                <input type="submit" value="Submit" style="color:white; background-color: #00a65a !important; width:300px; margin-left:24%;" />




                                            </form>


                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>


                    </div>
                </div>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->
    </div>





