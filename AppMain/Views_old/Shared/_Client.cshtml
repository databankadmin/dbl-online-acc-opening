@using AppUtils
@using DBHelper.Schema
@using AppModels

@{
    if (!Request.IsAuthenticated)
    {
        Response.Redirect(Url.Action("Logout", "Client"));
    }
    var currentUser = Utilities.GetSessionUserClient();
    Account user = null;
    if (currentUser is Account)
    {
        user = currentUser as Account;

    }
    else
    {
        Response.Redirect(Url.Action("Logout", "Account"));

    }

    var context = new DBLAccountOpeningContext();
    var checkStatus = context.Accounts.Find(MvcApplication.TempAccount.Id).StatusId;

    var errors = context.AccountEditRequests.Where(x => x.AccountId == MvcApplication.TempAccount.Id);
    AccountEditRequest latestReq = null;
    if (errors!=null)
    {
        latestReq = errors.OrderByDescending(x => x.CreatedDate).FirstOrDefault();

    }
    else
    {
        latestReq = new AccountEditRequest {DBLFormEnabled=true,AMLEnabled=true,FileUploadEnabled=true,ETIEnabled=true,IsActive=true };
    }

}
<!DOCTYPE html>
<html lang="en">
<head>
