    <script type="text/javascript">
    function confirmLogout() {
        bootbox.dialog(
            {
                title: "Confirm Action",
                message:"Logout of session?<br/>",

                buttons: {
                    success: {
                        label: "OK",
                        className: "btn-success",
                        callback: function () {
                            document.location.href = "@Url.Action("Logout", "Account")";
                        }
                    },
                    main: {
                        label: "Cancel",
                        className: "btn-danger",
                        callback: function () {

                        }
                    }

                }
            });


    }
    </script>



    @Html.Partial("_Prompt")



    <script type="text/javascript">

        $(function () {
            try {
                //   alert('loaded');
                $("input,select,textarea").focus(function () {
                    $("#" + this.name).css("border-color", "#ff0000");
                });

                $("input,select,textarea").focusout(function () {
                    $("#" + this.name).css("border-color", "green");
                });




            } catch (e) {

            }
        });



    </script>


    <script type="text/javascript">
        $(function () {
            @{


                if (checkStatus != 5)
                {
            <text>
            $("#appForm :input").prop("disabled", true);
            </text>
            }
        }
        });


    </script>

    <style type="text/css">
        i.fa fa-trash, .fa-trash {
