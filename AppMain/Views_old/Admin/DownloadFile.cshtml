
@{
    ViewBag.Title = "DownloadFile";
    Layout = "~/Views/Shared/_Admin.cshtml";
    string filePath = "../Images/" + ViewBag.path.ToString();
    string refNumber = ViewBag._refNumber.ToString();
}





<div class="col-md-12">
    <div class="card">
        <div class="card-header">
            <h3>File ready for Download</h3>
        </div>
        <div class="card-body">
            

            <p>
                <a href="@filePath" class="btn btn-success" download="@ViewBag.path.ToString()">Download File</a>

               <a class="btn btn-danger" href="@Url.Action("ApplicantProfile","Admin",new { _refNumber=refNumber})">Back</a>
            </p>
        </div>
        </div>
    </div>

