## .NET / Visual Studio gitignore — best practices
## Based on github/gitignore VisualStudio.gitignore (updated)

# ========================
# Build output
# ========================
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww]in32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# ========================
# Visual Studio
# ========================
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ========================
# .NET / NuGet
# ========================
project.lock.json
project.fragment.lock.json
artifacts/
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
# Uncomment to ignore NuGet lock files (lock files are useful for reproducible builds)
#packages.lock.json

# ========================
# Test results & coverage
# ========================
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
*.VisualState.xml
TestResults/
BenchmarkDotNet.Artifacts/
coverage*/
*.coverage
*.coveragexml
*.cobertura.xml

# ========================
# Publishing
# ========================
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.publishproj
PublishScripts/
csx/
*.build.csdef
ecf/
rcf/

# ========================
# Sensitive / secrets
# ========================
*.pfx
*.publishsettings
*.p12
.env
.env.*
!.env.example
# User secrets are stored outside the project; these appear only when manually copied in
**/secrets.json

# ========================
# Compiler / native artifacts
# ========================
*_i.c
*_p.c
*_i.h
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc
dlldata.c

# ========================
# ReSharper
# ========================
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ========================
# JetBrains Rider
# ========================
.idea/
*.sln.iml

# ========================
# Visual Studio Code
# ========================
.vscode/

# ========================
# Other VS add-ins / tools
# ========================
.JustCode
_TeamCity*
*.dotCover
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*
*.mm.*
AutoTest.Net/
.cr/
_Chutzpah*

# ========================
# Visual C++ cache
# ========================
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# ========================
# Visual Studio profiler
# ========================
*.psess
*.vsp
*.vspx
*.sap

# ========================
# Paket / FAKE
# ========================
.paket/paket.exe
paket-files/
.fake/

# ========================
# Node / frontend
# ========================
node_modules/
.sass-cache/
bower_components/

# ========================
# Python (PTVS)
# ========================
__pycache__/
*.pyc

# ========================
# Misc
# ========================
*.[Cc]ache
!*.[Cc]ache/
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
Generated_Code/
FakesAssemblies/
*.GhostDoc.xml
.ntvs_analysis.dat
$tf/
*.gpState
*.plg
*.opt
**/*.HTMLClient/GeneratedArtifacts
**/*.DesktopClient/GeneratedArtifacts
**/*.DesktopClient/ModelManifest.xml
**/*.Server/GeneratedArtifacts
**/*.Server/ModelManifest.xml
_Pvt_Extensions
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
[Ee]xpress/
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2
DocProject/Help/html

# Archives / large binaries
*.zip
*.7z
*.rar

# SQL Server
*.mdf
*.ldf
*.ndf

# Business Intelligence
*.rdl.data
*.bim.layout
*.bim_*.settings

# TFS
$tf/

# ========================
# Project-specific
# ========================
PdfFillerDemo/images/
AppMain/Images/
